{% extends 'admin/layout.html.twig' %}

{% block title %}Edit order {{ order.orderNumber }}{% endblock %}

{% block page_title %}Orders{% endblock %}

{% block breadcrumb_current %}Update {{ order.orderNumber }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/orders.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block admin_content %}
    {# Same form layout as the pencil modal on /orders — product.css required for stock-form-* styles #}
    <div class="stock-entry-page">
        <div class="stock-entry-header">
            <div class="stock-entry-header-left">
                <div class="stock-entry-section-label">ORDER MANAGEMENT</div>
                <h1 class="stock-entry-title">Update · #{{ order.orderNumber }}</h1>
            </div>
            <div class="stock-entry-header-right">
                <a href="{{ path('app_orders') }}" class="stock-entry-back-btn">
                    <i class="fa fa-arrow-left"></i>
                    Back to orders
                </a>
            </div>
        </div>

        {% for message in app.flashes('error') %}
            <div class="flash-messages">
                <div class="flash-message flash-error">{{ message }}</div>
            </div>
        {% endfor %}

        <div class="stock-entry-form-container">
            {{ include('orders/_status_form.html.twig', {
                form: form,
                order: order,
                button_label: 'Update Order Status',
                action: path('app_orders_edit', { id: order.id }),
                show_cancel: true
            }) }}
        </div>
    </div>
{% endblock %}
