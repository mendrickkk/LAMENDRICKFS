{% extends 'admin/layout.html.twig' %}

{% block title %}Orders Dashboard{% endblock %}

{% block page_title %}Orders{% endblock %}

{% block breadcrumb_current %}Orders{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/orders.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block admin_content %}
    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div class="flash-message flash-success">{{ message }}</div>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash-messages">
            <div class="flash-message flash-error">{{ message }}</div>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="fa fa-receipt"></i>
                Recent Orders
                <span id="pendingOrdersBadge" class="status-badge status-pending" style="margin-left: 12px;">
                    <span class="status-badge-dot"></span>
                    Pending: <strong id="pendingOrdersCount">{{ pendingCount|default(0) }}</strong>
                </span>
            </div>
        </div>
        <div class="card-body card-body-no-padding">
            <div class="orders-bulk-actions" id="ordersBulkActions" style="display: none;">
                <span id="ordersSelectedCount" class="orders-bulk-actions__count">0 selected</span>
                <form method="post" action="{{ path('app_orders_bulk_delete') }}" id="ordersBulkDeleteForm" onsubmit="return confirm('Delete the selected orders? This cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('bulk_delete') }}">
                    <input type="hidden" name="ids" id="ordersBulkDeleteIds">
                    <button type="submit" class="card-action-btn product-action-btn product-action-btn-delete orders-bulk-delete-btn">
                        <i class="fa fa-trash"></i>
                        Delete Selected
                    </button>
                </form>
            </div>
            <div class="table-responsive orders-table-wrap">
                <table class="table orders-table"
                       data-orders-stream-url="{{ path('app_orders_stream_new') }}"
                       data-orders-poll-url="{{ path('app_orders_realtime_recent') }}"
                       data-order-view-url-template="{{ path('app_orders_show', { id: 999999999 })|replace({'999999999': '__ID__'}) }}"
                       data-order-edit-url-template="{{ path('app_orders_edit', { id: 999999999 })|replace({'999999999': '__ID__'}) }}">
                    <thead>
                        <tr>
                            <th class="orders-table-checkbox-col">
                                <input type="checkbox" id="selectAllOrders" aria-label="Select all orders">
                            </th>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                        {% if recentOrders is not empty %}
                            {% for order in recentOrders %}
                                <tr class="order-row" data-id="{{ order.id }}">
                                    <td class="orders-table-checkbox-col">
                                        <input type="checkbox" class="order-checkbox" value="{{ order.id }}" aria-label="Select order {{ order.orderNumber }}">
                                    </td>
                                    <td style="font-weight: 600; color: #ec4899; font-family: 'Courier New', monospace;">
                                        #{{ order.orderNumber }}
                                    </td>
                                    <td style="font-weight: 500; color: #111827;">{{ order.customerName }}</td>
                                    <td>
                                        <span class="status-badge status-{{ order.status|lower }}">
                                            <span class="status-badge-dot"></span>
                                            {{ order.status }}
                                        </span>
                                    </td>
                                    <td style="font-weight: 600; color: #059669; font-family: 'Courier New', monospace;">₱{{ order.total|number_format(2, '.', ',') }}</td>
                                    <td style="color: #6b7280; font-size: 13px;">{{ order.createdAt|date('M d, Y') }}</td>
                                    <td>
                                        <div class="product-actions-cell">
                                            <a href="{{ path('app_orders_show', { id: order.id }) }}"
                                               class="card-action-btn product-action-btn"
                                               data-view-order-modal="true"
                                               data-order-id="{{ order.id }}"
                                               data-order-number="{{ order.orderNumber }}"
                                               title="View order">
                                                <i class="fa fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_orders_edit', { id: order.id }) }}"
                                               class="card-action-btn product-action-btn product-action-btn-edit"
                                               data-edit-order-modal="true"
                                               data-order-id="{{ order.id }}"
                                               data-order-number="{{ order.orderNumber }}"
                                               title="Update status">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="7" style="text-align: center; padding: 40px 20px; color: #9ca3af;">
                                    <i class="fa fa-inbox" style="font-size: 32px; margin-bottom: 12px; display: block;"></i>
                                    <span>No orders found</span>
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# View order modal #}
    <div class="admin-modal" id="viewOrderModal" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="viewOrderModalTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">ORDER MANAGEMENT</div>
                    <div class="admin-modal__title" id="viewOrderModalTitle">Order Details</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>
            <div class="admin-modal__body" id="viewOrderModalBody"></div>
        </div>
    </div>

    {# Update status modal (same pattern as stock edit) #}
    <div class="admin-modal" id="editOrderModal" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="editOrderModalTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">ORDER MANAGEMENT</div>
                    <div class="admin-modal__title" id="editOrderModalTitle">Update Order Status</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>
            <div class="admin-modal__body" id="editOrderModalBody"></div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const selectAllOrders = document.getElementById('selectAllOrders');
            const bulkActionsBar = document.getElementById('ordersBulkActions');
            const selectedCountEl = document.getElementById('ordersSelectedCount');
            const bulkDeleteIdsInput = document.getElementById('ordersBulkDeleteIds');
            const ordersTable = document.querySelector('.orders-table');
            const ordersTableBody = document.getElementById('ordersTableBody');
            const pendingOrdersCountEl = document.getElementById('pendingOrdersCount');
            const seenOrderIds = new Set(
                Array.from(document.querySelectorAll('.order-row[data-id]'))
                    .map(function(row) { return Number(row.getAttribute('data-id')); })
                    .filter(function(id) { return Number.isFinite(id); })
            );

            let realtimeConnected = false;
            let fallbackPollTimer = null;

            function getOrderCheckboxes() {
                return Array.from(document.querySelectorAll('.order-checkbox'));
            }

            function updateBulkActionsBar() {
                const checked = getOrderCheckboxes().filter(function(cb) { return cb.checked; });
                const count = checked.length;

                if (!bulkActionsBar || !selectedCountEl || !bulkDeleteIdsInput) {
                    return;
                }

                if (count > 0) {
                    bulkActionsBar.style.display = 'flex';
                    bulkActionsBar.style.alignItems = 'center';
                    bulkActionsBar.style.justifyContent = 'space-between';
                    selectedCountEl.textContent = count + ' selected';
                    bulkDeleteIdsInput.value = checked.map(function(cb) { return cb.value; }).join(',');
                } else {
                    bulkActionsBar.style.display = 'none';
                    bulkDeleteIdsInput.value = '';
                }

                if (selectAllOrders) {
                    const all = getOrderCheckboxes();
                    selectAllOrders.checked = all.length > 0 && count === all.length;
                    selectAllOrders.indeterminate = count > 0 && count < all.length;
                }
            }

            function escapeHtml(value) {
                return String(value ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function formatAmount(total) {
                const numeric = Number(total || 0);
                return '₱' + numeric.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function formatDate(createdAt) {
                const date = createdAt ? new Date(createdAt) : new Date();
                return date.toLocaleDateString(undefined, { month: 'short', day: '2-digit', year: 'numeric' });
            }

            function normalizeStatus(status) {
                const safe = String(status || 'pending').trim();
                return safe === '' ? 'pending' : safe;
            }

            function toStatusClass(status) {
                return normalizeStatus(status).toLowerCase().replace(/[^a-z0-9_-]/g, '-');
            }

            function updatePendingCountUi() {
                if (!pendingOrdersCountEl) return;
                const pendingRows = document.querySelectorAll('.order-row .status-badge.status-pending').length;
                pendingOrdersCountEl.textContent = String(pendingRows);
            }

            function showNewOrderToast(orderNumber) {
                const toast = document.createElement('div');
                toast.className = 'flash-messages';
                toast.innerHTML = '<div class="flash-message flash-success">New order received: #' + escapeHtml(orderNumber) + '</div>';
                document.body.appendChild(toast);
                setTimeout(function() {
                    toast.remove();
                }, 3500);
            }

            function createOrderRowHtml(order) {
                const orderId = Number(order.orderId);
                const orderNumber = escapeHtml(order.orderNumber || '');
                const customerName = escapeHtml(order.customerName || 'Unknown customer');
                const status = normalizeStatus(order.status);
                const statusClass = toStatusClass(status);
                const viewUrlTemplate = ordersTable ? (ordersTable.getAttribute('data-order-view-url-template') || '/orders/__ID__') : '/orders/__ID__';
                const editUrlTemplate = ordersTable ? (ordersTable.getAttribute('data-order-edit-url-template') || '/orders/__ID__/edit') : '/orders/__ID__/edit';
                const viewUrl = viewUrlTemplate.replace('__ID__', String(orderId));
                const editUrl = editUrlTemplate.replace('__ID__', String(orderId));

                return '' +
                    '<tr class="order-row" data-id="' + orderId + '">' +
                        '<td class="orders-table-checkbox-col">' +
                            '<input type="checkbox" class="order-checkbox" value="' + orderId + '" aria-label="Select order ' + orderNumber + '">' +
                        '</td>' +
                        '<td style="font-weight: 600; color: #ec4899; font-family: \'Courier New\', monospace;">#' + orderNumber + '</td>' +
                        '<td style="font-weight: 500; color: #111827;">' + customerName + '</td>' +
                        '<td><span class="status-badge status-' + statusClass + '"><span class="status-badge-dot"></span>' + escapeHtml(status) + '</span></td>' +
                        '<td style="font-weight: 600; color: #059669; font-family: \'Courier New\', monospace;">' + formatAmount(order.total) + '</td>' +
                        '<td style="color: #6b7280; font-size: 13px;">' + escapeHtml(formatDate(order.createdAt)) + '</td>' +
                        '<td>' +
                            '<div class="product-actions-cell">' +
                                '<a href="' + escapeHtml(viewUrl) + '" class="card-action-btn product-action-btn" data-view-order-modal="true" data-order-id="' + orderId + '" data-order-number="' + orderNumber + '" title="View order"><i class="fa fa-eye"></i></a>' +
                                '<a href="' + escapeHtml(editUrl) + '" class="card-action-btn product-action-btn product-action-btn-edit" data-edit-order-modal="true" data-order-id="' + orderId + '" data-order-number="' + orderNumber + '" title="Update status"><i class="fa fa-pencil"></i></a>' +
                            '</div>' +
                        '</td>' +
                    '</tr>';
            }

            function prependOrderRow(order, showToast) {
                if (!ordersTableBody) return;
                const orderId = Number(order.orderId);
                if (!Number.isFinite(orderId) || seenOrderIds.has(orderId)) {
                    return;
                }

                const emptyRow = ordersTableBody.querySelector('tr td[colspan="7"]');
                if (emptyRow) {
                    emptyRow.parentElement.remove();
                }

                ordersTableBody.insertAdjacentHTML('afterbegin', createOrderRowHtml(order));
                seenOrderIds.add(orderId);
                updateBulkActionsBar();
                updatePendingCountUi();
                if (showToast) {
                    showNewOrderToast(order.orderNumber);
                }
            }

            async function pollRecentOrders() {
                if (!ordersTable) return;
                const pollUrl = ordersTable.getAttribute('data-orders-poll-url');
                if (!pollUrl) return;
                try {
                    const res = await fetch(pollUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (!res.ok) return;
                    const data = await res.json();
                    const orders = Array.isArray(data.orders) ? data.orders : [];
                    orders
                        .sort(function(a, b) { return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime(); })
                        .forEach(function(order) { prependOrderRow(order, false); });
                } catch (err) {
                    console.warn('orders poll failed', err);
                }
            }

            function startFallbackPolling() {
                if (fallbackPollTimer !== null) return;
                fallbackPollTimer = window.setInterval(pollRecentOrders, 45000);
            }

            function stopFallbackPolling() {
                if (fallbackPollTimer === null) return;
                window.clearInterval(fallbackPollTimer);
                fallbackPollTimer = null;
            }

            function connectRealtimeStream() {
                if (!ordersTable || typeof window.EventSource !== 'function') {
                    startFallbackPolling();
                    return;
                }

                const streamUrl = ordersTable.getAttribute('data-orders-stream-url');
                if (!streamUrl) {
                    startFallbackPolling();
                    return;
                }

                const source = new EventSource(streamUrl, { withCredentials: true });

                source.addEventListener('open', function() {
                    realtimeConnected = true;
                    stopFallbackPolling();
                });

                source.addEventListener('new-order', function(event) {
                    try {
                        const payload = JSON.parse(event.data);
                        prependOrderRow(payload, true);
                    } catch (err) {
                        console.error('Invalid realtime order payload', err);
                    }
                });

                source.onerror = function() {
                    if (realtimeConnected) {
                        realtimeConnected = false;
                    }
                    startFallbackPolling();
                };
            }

            if (selectAllOrders) {
                selectAllOrders.addEventListener('change', function() {
                    const checked = selectAllOrders.checked;
                    getOrderCheckboxes().forEach(function(cb) {
                        cb.checked = checked;
                    });
                    updateBulkActionsBar();
                });
            }

            getOrderCheckboxes().forEach(function(cb) {
                cb.addEventListener('change', updateBulkActionsBar);
            });

            document.addEventListener('change', function(ev) {
                if (ev.target && ev.target.matches('.order-checkbox')) {
                    updateBulkActionsBar();
                }
            });

            const viewModal = document.getElementById('viewOrderModal');
            const viewModalBody = document.getElementById('viewOrderModalBody');

            const editModal = document.getElementById('editOrderModal');
            const editModalBody = document.getElementById('editOrderModalBody');
            const editModalTitle = document.getElementById('editOrderModalTitle');

            function openModal(modal) {
                if (!modal) return;
                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
            }

            function closeModal(modal, body) {
                if (!modal) return;
                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
                if (body) body.innerHTML = '';
            }

            const viewModalTitle = document.getElementById('viewOrderModalTitle');

            async function loadOrderView(url, orderNumber) {
                if (!url || !viewModalBody) return;
                if (viewModalTitle && orderNumber) {
                    viewModalTitle.textContent = 'View · #' + orderNumber;
                }
                const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) throw new Error('Could not load order');
                viewModalBody.innerHTML = await res.text();
                openModal(viewModal);
            }

            async function loadOrderEdit(url, orderNumber) {
                if (!url || !editModalBody) return;
                if (editModalTitle && orderNumber) {
                    editModalTitle.textContent = 'Update · #' + orderNumber;
                }
                const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) throw new Error('Could not load form');
                editModalBody.innerHTML = await res.text();
                openModal(editModal);
            }

            function findOrderLink(kind, orderId) {
                const selector = kind === 'view'
                    ? 'a[data-view-order-modal="true"][data-order-id="' + orderId + '"]'
                    : 'a[data-edit-order-modal="true"][data-order-id="' + orderId + '"]';
                return document.querySelector(selector);
            }

            async function openOrderViewById(orderId) {
                const link = findOrderLink('view', orderId);
                if (!link) return;
                await loadOrderView(link.getAttribute('href'), link.getAttribute('data-order-number'));
            }

            async function openOrderEditById(orderId) {
                const link = findOrderLink('edit', orderId);
                if (!link) return;
                await loadOrderEdit(link.getAttribute('href'), link.getAttribute('data-order-number'));
            }

            document.addEventListener('click', async function(ev) {
                const viewLink = ev.target.closest('a[data-view-order-modal="true"]');
                if (viewLink) {
                    ev.preventDefault();
                    try {
                        await loadOrderView(viewLink.getAttribute('href'), viewLink.getAttribute('data-order-number'));
                    } catch (err) {
                        console.error(err);
                    }
                    return;
                }

                const editLink = ev.target.closest('a[data-edit-order-modal="true"]');
                if (editLink) {
                    ev.preventDefault();
                    try {
                        await loadOrderEdit(editLink.getAttribute('href'), editLink.getAttribute('data-order-number'));
                    } catch (err) {
                        console.error(err);
                    }
                }
            });

            document.addEventListener('click', async function(ev) {
                const editBtn = ev.target.closest('[data-open-edit-order]');
                if (!editBtn) return;
                ev.preventDefault();
                const orderId = editBtn.getAttribute('data-open-edit-order');
                closeModal(viewModal, viewModalBody);
                try {
                    await openOrderEditById(orderId);
                } catch (err) {
                    console.error(err);
                }
            });

            const params = new URLSearchParams(window.location.search);
            const openViewId = params.get('openView');
            const openEditId = params.get('openEdit');
            if (openViewId || openEditId) {
                const cleanUrl = new URL(window.location.href);
                cleanUrl.searchParams.delete('openView');
                cleanUrl.searchParams.delete('openEdit');
                window.history.replaceState({}, '', cleanUrl.pathname + cleanUrl.search);
            }
            if (openViewId) {
                openOrderViewById(openViewId).catch(console.error);
            } else if (openEditId) {
                openOrderEditById(openEditId).catch(console.error);
            }

            if (viewModal) {
                viewModal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close="true"]')) {
                        closeModal(viewModal, viewModalBody);
                    }
                });
            }

            if (editModal) {
                editModal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close="true"]')) {
                        closeModal(editModal, editModalBody);
                    }
                });
            }

            document.addEventListener('keydown', function(e) {
                if (e.key !== 'Escape') return;
                if (viewModal && viewModal.classList.contains('is-open')) {
                    closeModal(viewModal, viewModalBody);
                }
                if (editModal && editModal.classList.contains('is-open')) {
                    closeModal(editModal, editModalBody);
                }
            });

            document.addEventListener('submit', async function(e) {
                const formEl = e.target;
                if (!editModal || !editModal.classList.contains('is-open')) return;
                if (!formEl || !formEl.matches('form[data-order-form="true"]')) return;

                e.preventDefault();
                try {
                    const res = await fetch(formEl.action, {
                        method: 'POST',
                        body: new FormData(formEl),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (res.ok) {
                        const data = await res.json();
                        window.location.href = (data && data.redirectUrl) ? data.redirectUrl : window.location.href;
                        return;
                    }

                    const html = await res.text();
                    if (editModalBody) editModalBody.innerHTML = html;
                } catch (err) {
                    formEl.submit();
                }
            });

            connectRealtimeStream();
            updatePendingCountUi();
        });
    </script>
{% endblock %}
