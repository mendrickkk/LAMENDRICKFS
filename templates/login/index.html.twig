{% extends 'base.html.twig' %}

{% block title %}Login · La Kurt Flowershop{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/loginn.css') }}">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
{% endblock %}

{% block body %}
<div class="fv-page fv-login-page">
    {% include 'client/_header.html.twig' %}

    <main class="fv-main" role="main">
        <div class="fv-login">
            <h1 class="fv-login__title">LOGIN</h1>
            <p class="fv-login__lead">Please enter your e-mail and password:</p>

            <div class="fv-login__alerts">
                {% for message in app.flashes('success') %}
                    <div class="fv-login__alert fv-login__alert--success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="fv-login__alert fv-login__alert--warning">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="fv-login__alert fv-login__alert--error">{{ message }}</div>
                {% endfor %}

                {% if error %}
                    <div class="fv-login__alert fv-login__alert--error">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}
            </div>

            {% if error and 'verify your email' in (error.messageKey|lower) %}
                <form class="fv-login__resend" method="post" action="{{ path('app_email_verify_resend') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification') }}">
                    <div class="fv-login__field">
                        <input class="fv-login__input" type="email" name="identifier" value="{{ last_username }}" placeholder="Email" required autocomplete="email">
                    </div>
                    <button id="resend-verification-submit" class="fv-login__submit" type="submit">Resend verification email</button>
                </form>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="fv-login__field">
                    <input class="fv-login__input" type="email" id="login-email" name="_username" value="{{ last_username }}" placeholder="Email" required autocomplete="email">
                </div>

                <div class="fv-login__field">
                    <div class="fv-login__password-row">
                        <div class="fv-login__password-wrap">
                            <input class="fv-login__input" type="password" id="password" name="_password" placeholder="Password" required autocomplete="current-password">
                            <button type="button" class="fv-login__eye" id="togglePassword" aria-label="Show password">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                        </div>
                        <a class="fv-login__forgot" href="#">Forgot password?</a>
                    </div>
                </div>

                <button class="fv-login__submit" type="submit">LOGIN</button>

                <div class="fv-login__divider" aria-hidden="true">
                    <span>OR</span>
                </div>
            </form>

            <a href="{{ path('connect_google_start') }}" class="fv-login__google">
                <span class="fv-login__google-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21.6 12.25c0-.67-.06-1.3-.18-1.92H12v3.64h5.37c-.23 1.23-.91 2.28-1.94 2.98v2.41h3.13c1.83-1.68 2.9-4.15 2.9-7.11Z" fill="#4285F4"/>
                        <path d="M12 22c2.57 0 4.73-.85 6.31-2.31l-3.13-2.41c-.87.59-1.98.94-3.18.94-2.45 0-4.52-1.65-5.26-3.87H3.49v2.49C5.06 19.83 8.26 22 12 22Z" fill="#34A853"/>
                        <path d="M6.74 13.35c-.19-.59-.3-1.22-.3-1.87 0-.65.11-1.28.3-1.87V7.12H3.49A9.98 9.98 0 0 0 2 11.48c0 1.6.39 3.1 1.49 4.36l3.25-2.49Z" fill="#FBBC05"/>
                        <path d="M12 4.88c1.4 0 2.65.48 3.63 1.42l2.72-2.72C16.72 1.98 14.56 1 12 1 8.26 1 5.06 3.17 3.49 6.52l3.25 2.49c.74-2.22 2.81-3.87 5.26-3.87Z" fill="#EA4335"/>
                    </svg>
                </span>
                Continue with Google
            </a>

            <p class="fv-login__google-note">
                Staff members can sign in with their Google account.
            </p>

            <p class="fv-login__footer">
                Don't have an account? <a href="{{ path('app_signup') }}">Create one</a>
            </p>
        </div>
    </main>

    {% include 'client/footer.html.twig' %}
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const passwordInput = document.getElementById('password');
        const togglePassword = document.getElementById('togglePassword');
        if (togglePassword && passwordInput) {
            togglePassword.addEventListener('click', function() {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                togglePassword.setAttribute('aria-label', type === 'password' ? 'Show password' : 'Hide password');
            });
        }

        const resendForm = document.querySelector('form.fv-login__resend');
        const resendSubmit = document.getElementById('resend-verification-submit');
        if (resendForm && resendSubmit) {
            resendForm.addEventListener('submit', function() {
                // Prevent double-click spamming in Gmail/Brevo.
                resendSubmit.disabled = true;
                resendSubmit.textContent = 'Sending...';
            });
        }
    });
</script>
{% endblock %}
