{% extends 'base.html.twig' %}

{% block title %}Welcome · KM+BP Flower Shop{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/landing.css') }}">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="landing-wrapper">
    <div class="landing-card">
        <div class="landing-header">
            <div class="brand-top"><span class="brand-dot"></span> KM+BP Flower Shop</div>
            <h1 class="landing-title">Choose how you want to continue</h1>
            <p class="landing-subtitle">Select a portal below to get started</p>
        </div>

        <div class="options-grid">
            <!-- Admin Option -->
            <section class="option">
                <span class="option-badge badge-admin">Admin</span>
                <div class="decor"></div>
                <div class="option-icon icon-admin">
                    <i class="fa fa-gauge"></i>
                </div>
                <h2 class="option-title">Admin Portal</h2>
                <p class="option-text">Manage products, orders, users, and analytics in one place.</p>
                <div class="option-footer">
                    <a class="btn btn-primary" href="{{ path('app_signup') }}?type=admin">
                        Continue as Admin <i class="fa fa-arrow-right"></i>
                    </a>
                    <span class="option-meta"><i class="fa fa-shield"></i> Secure access</span>
                </div>
            </section>

            <!-- Client Option -->
            <section class="option">
                <span class="option-badge badge-client">Client</span>
                <div class="decor"></div>
                <div class="option-icon icon-client">
                    <i class="fa fa-user"></i>
                </div>
                <h2 class="option-title">Client Portal</h2>
                <p class="option-text">Sign in to view orders, track deliveries, and manage your profile.</p>
                <div class="option-footer">
                    <a class="btn btn-success" href="{{ path('app_signup') }}?type=client">
                        Continue as Client <i class="fa fa-arrow-right"></i>
                    </a>
                    <span class="option-meta"><i class="fa fa-seedling"></i> Personalized</span>
                </div>
            </section>
        </div>
    </div>
</div>
{% endblock %}
