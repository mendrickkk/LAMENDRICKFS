{% extends 'base.html.twig' %}

{% block title %}KM+BP - Premium Flower Shop{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/client.css') }}">
{% endblock %}

{% block body %}
<!-- Header -->
<header class="header">
    <!-- Top Bar -->
    <div class="header-top">
        <div class="header-container">
            <a href="{{ path('app_landing') }}" class="logo">
                <span class="logo-small">KM+BP</span>
                
            </a>
            <div class="header-right">
                <a href="#" class="header-link">Store Locations</a>
                <a href="#" class="header-link">Track Order</a>
                <a href="#" class="header-link">Help</a>
                <a href="#" class="icon-link">
                    <svg class="header-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                    </svg>
                </a>
                <a href="#" class="icon-link">
                    <svg class="header-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
                    </svg>
                    <span class="cart-badge">0</span>
                </a>
            </div>
        </div>
    </div>
    
    <!-- Main Navigation -->
    <nav class="main-nav">
        <div class="header-container">
            <div class="nav-links">
                <a href="#" class="nav-link">All Flowers <span class="dropdown-arrow">▼</span></a>
                <a href="#" class="nav-link">Occasions <span class="dropdown-arrow">▼</span></a>
                <a href="#" class="nav-link">Fall</a>
                <a href="#" class="nav-link">Halloween</a>
                <a href="#" class="nav-link">Birthday</a>
                <a href="#" class="nav-link">Next Day</a>
                <a href="#" class="nav-link">Same Day</a>
                <a href="#" class="nav-link">Weddings <span class="dropdown-arrow">▼</span></a>
                <a href="#" class="nav-link">Subscriptions <span class="dropdown-arrow">▼</span></a>
            </div>
        </div>
    </nav>
</header>

<!-- Hero Banner -->
<section class="hero-banner">
    <div class="hero-content">
        <p class="hero-badge">BOUQSDAY SAVINGS</p>
        <h1 class="hero-title">Get 25% Off</h1>
        <p class="hero-subtitle">Save big on fall favorites, spooky stems, and more with code BOUQSDAY.</p>
        <a href="{{ path('app_product_index') }}" class="btn btn-hero">Shop Now</a>
    </div>
    <div class="hero-image">
        <!-- You can insert your hero image here -->
        <div class="hero-image-placeholder">
            <p>Hero Image Placeholder</p>
            <p>Insert your floral arrangement image here</p>
        </div>
    </div>
</section>

<!-- Announcement Bar -->
<div class="announcement-bar">
    <p>Marigolds, strawflower, calla lilies, and more—the best of autumn is now in bloom. <a href="{{ path('app_product_index') }}">Shop Unique Stems</a></p>
</div>

<!-- Main Body Content -->
<main class="main-body">
    <!-- Best Selling Bouquets Section -->
    <section class="best-selling">
        <h2 class="section-title">Best-Selling Bouqs</h2>
        <div class="product-grid">
            <div class="product-card">
                <div class="product-image">
                    <img src="{{ asset('images/2.avif') }}" alt="Sweater Weather">
                </div>
                <h3 class="product-name">Sweater Weather</h3>
                <p class="product-price">from $64</p>
                <p class="product-shipping">Subscribe for 30% off + free shipping</p>
                <p class="product-sub-price">from $45</p>
            </div>
            <div class="product-card">
                <div class="product-image">
                    <img src="{{ asset('images/3.avif') }}" alt="Buttercream">
                </div>
                <h3 class="product-name">Buttercream</h3>
                <p class="product-price">from $69</p>
                <p class="product-shipping">Subscribe for 30% off + free shipping</p>
                <p class="product-sub-price">from $49</p>
            </div>
            <div class="product-card">
                <div class="product-image">
                    <img src="{{ asset('images/4.avif') }}" alt="Black Magic">
                </div>
                <h3 class="product-name">Black Magic</h3>
                <p class="product-price">from $64</p>
                <p class="product-shipping">Subscribe for 30% off + free shipping</p>
                <p class="product-sub-price">from $45</p>
            </div>
            <div class="product-card">
                <div class="product-image">
                    <img src="{{ asset('images/5.avif') }}" alt="Glowing">
                </div>
                <h3 class="product-name">Glowing</h3>
                <p class="product-price">from $64</p>
                <p class="product-shipping">Subscribe for 30% off + free shipping</p>
                <p class="product-sub-price">from $45</p>
            </div>
        </div>
        <div class="view-all-container">
            <a href="{{ path('app_product_index') }}" class="btn btn-secondary">SHOP ALL BEST SELLERS</a>
        </div>
    </section>

    <!-- Monthly Flower Subscriptions Section -->
    <section class="subscription-section">
        <div class="subscription-content">
            <p class="subscription-reviews">50,000 5-STAR REVIEWS</p>
            <h2 class="subscription-title">Monthly Flower Subscriptions</h2>
            <p class="subscription-text">Knock, knock—fresh flowers delivered straight to your door with <strong>FREE shipping</strong> every month.</p>
            <a href="#" class="btn btn-dark-green">Start A Subscription</a>
        </div>
        <div class="subscription-image">
            <img src="{{ asset('images/6.avif') }}" alt="Monthly flower subscription">
        </div>
    </section>

    <!-- Wedding Flowers Section -->
    <section class="wedding-section">
        <div class="wedding-image">
            <img src="{{ asset('images/7.avif') }}" alt="Wedding flowers">
        </div>
        <div class="wedding-content">
            <h2 class="wedding-title">Wedding Flowers, Your Way</h2>
            <p class="wedding-text">From full-service floral designs to ready-to-go arrangements, we'll help bring your dream wedding to life.</p>
            <a href="#" class="btn btn-dark-green">Learn More About Weddings</a>
        </div>
    </section>

    <!-- Corporate Gifts Section -->
    <section class="corporate-section">
        <div class="corporate-content">
            <p class="corporate-badge">CORPORATE GIFTS</p>
            <h2 class="corporate-title">Flowers That Mean Business</h2>
            <p class="corporate-text">Universally appreciated bouquets, plants, and gifts for your clients and employees.</p>
            <a href="#" class="btn btn-dark-green">Get In Touch</a>
        </div>
        <div class="corporate-image">
            <img src="{{ asset('images/8.avif') }}" alt="Corporate gifts">
        </div>
    </section>
</main>

<!-- Final Call-to-Action Section -->
<section class="final-cta-section">
    <div class="cta-content">
        <img src="{{ asset('images/11.avif') }}" alt="Final call to action" class="cta-image">
        <div class="cta-text">
            <h2>Ready to Get Started?</h2>
            <p>Contact us today for all your floral needs</p>
            <a href="#" class="btn">Get In Touch</a>
        </div>
    </div>
</section>

<!-- FAQ Accordions -->
<section class="faq-section">
    <div class="faq-item">
        <h3 class="faq-title">Flower Delivery for Every Occasion by KM+BP Co. ⭐</h3>
    </div>
    <div class="faq-item">
        <h3 class="faq-title">Send Flowers Gifts You Need ➜</h3>
    </div>
    <div class="faq-item">
        <h3 class="faq-title">How-to-about Flower Bouquets by Expert Florists ⭐</h3>
    </div>
    <div class="faq-item">
        <h3 class="faq-title">Insightful Flowers Whenever You Need Them 💐</h3>
    </div>
    <div class="faq-item">
        <h3 class="faq-title">Choose Bougie for Your Next Flower Delivery 🌸</h3>
    </div>
</section>

