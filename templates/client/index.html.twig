{% extends 'base.html.twig' %}

{% block title %}La Kurt Flowershop{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/client.css') }}">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
{% if header_only is defined and header_only %}
    <header class="fv-topbar" role="banner">
        <div class="fv-topbar__inner">
            <div class="fv-topbar__left" aria-hidden="true"></div>

            <a class="fv-brand" href="{{ path('app_client') }}">
                <img class="fv-brand__mark" src="{{ asset('img/logo1.png') }}" alt="La Kurt Flowershop">
                <span class="fv-brand__text">
                    <span class="fv-brand__name">LA KURT</span>
                    <span class="fv-brand__tag">FLOWERSHOP</span>
                </span>
            </a>

            <nav class="fv-topbar__right" aria-label="Utility">
                <a class="fv-link" href="{{ path('app_login') }}">ACCOUNT</a>
                <a class="fv-link" href="#">SEARCH</a>
                <a class="fv-link" href="#">CART (0)</a>
            </nav>
        </div>

        <nav class="fv-nav" aria-label="Primary">
            <ul class="fv-nav__list">
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_client' ? 'is-active' : '' }}"><a href="{{ path('app_client') }}">HOME</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_shop' ? 'is-active' : '' }}"><a href="{{ path('app_shop') }}">SHOP</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_about' ? 'is-active' : '' }}"><a href="{{ path('app_about') }}">ABOUT</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_faq' ? 'is-active' : '' }}"><a href="{{ path('app_faq') }}">FAQ</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_contact' ? 'is-active' : '' }}"><a href="{{ path('app_contact') }}">CONTACT US</a></li>
            </ul>
        </nav>
    </header>
{% else %}
<div class="fv-page">
    <header class="fv-topbar" role="banner">
        <div class="fv-topbar__inner">
            <div class="fv-topbar__left" aria-hidden="true"></div>

            <a class="fv-brand" href="{{ path('app_client') }}">
                <img class="fv-brand__mark" src="{{ asset('img/logo1.png') }}" alt="La Kurt Flowershop">
                <span class="fv-brand__text">
                    <span class="fv-brand__name">LA KURT</span>
                    <span class="fv-brand__tag">FLOWERSHOP</span>
                </span>
            </a>

            <nav class="fv-topbar__right" aria-label="Utility">
                <a class="fv-link" href="{{ path('app_login') }}">ACCOUNT</a>
                <a class="fv-link" href="#">SEARCH</a>
                <a class="fv-link" href="#">CART (0)</a>
            </nav>
        </div>

        <nav class="fv-nav" aria-label="Primary">
            <ul class="fv-nav__list">
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_client' ? 'is-active' : '' }}"><a href="{{ path('app_client') }}">HOME</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_shop' ? 'is-active' : '' }}"><a href="{{ path('app_shop') }}">SHOP</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_about' ? 'is-active' : '' }}"><a href="{{ path('app_about') }}">ABOUT</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_faq' ? 'is-active' : '' }}"><a href="{{ path('app_faq') }}">FAQ</a></li>
                <li class="fv-nav__item {{ app.request.get('_route') == 'app_contact' ? 'is-active' : '' }}"><a href="{{ path('app_contact') }}">CONTACT US</a></li>
            </ul>
        </nav>
    </header>

    <main class="fv-main" role="main">
        <section class="fv-hero">
            <div class="fv-hero__content">
                <h1 class="fv-hero__title">WE MAKE EVERY MOMENT BLOOM</h1>
                <p class="fv-hero__text">Surprise your loved ones with La Kurt's latest collection of fresh flowers!</p>
                <a href="#" class="fv-hero__link">Bouquets</a>
            </div>
            <div class="fv-hero__image-wrapper">
                <img src="{{ asset('images/hero.png') }}" alt="Elegant Floral Arrangement" class="fv-hero__image">
            </div>
        </section>

        <section class="fv-products">
            <div class="fv-products__header">
                <h2 class="fv-products__title">BOUQUETS</h2>
            </div>
            
            <div class="fv-products__grid">
                {# Row 1: PNGs #}
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/11flowers.png') }}" alt="Kiera Fresh Bouquet" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">KIERA FRESH BOUQUET</h3>
                        <p class="fv-product-card__price">P3,960</p>
                    </div>
                </div>
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/22flowers.png') }}" alt="Lilianne Bouquet" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">LILIANNE BOUQUET</h3>
                        <p class="fv-product-card__price">P4,550</p>
                    </div>
                </div>
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/33flowers.png') }}" alt="Linnea Bouquet" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">LINNEA BOUQUET</h3>
                        <p class="fv-product-card__price">P4,800</p>
                    </div>
                </div>
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/44flowers.png') }}" alt="Candice Bouquet" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">CANDICE BOUQUET</h3>
                        <p class="fv-product-card__price">P4,800</p>
                    </div>
                </div>

                {# Row 2: AVIFs #}
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/2.avif') }}" alt="Classic Rose" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">CLASSIC ROSE</h3>
                        <p class="fv-product-card__price">P2,500</p>
                    </div>
                </div>
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/3.avif') }}" alt="Spring Bloom" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">SPRING BLOOM</h3>
                        <p class="fv-product-card__price">P3,200</p>
                    </div>
                </div>
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/4.avif') }}" alt="Sunset Glow" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">SUNSET GLOW</h3>
                        <p class="fv-product-card__price">P2,800</p>
                    </div>
                </div>
                <div class="fv-product-card">
                    <div class="fv-product-card__image-box">
                        <img src="{{ asset('images/5.avif') }}" alt="Midnight Petal" class="fv-product-card__img">
                    </div>
                    <div class="fv-product-card__info">
                        <h3 class="fv-product-card__name">MIDNIGHT PETAL</h3>
                        <p class="fv-product-card__price">P4,100</p>
                    </div>
                </div>
            </div>

            <div class="fv-products__footer">
                <a href="{{ path('app_shop') }}" class="fv-btn fv-btn--primary">VIEW ALL PRODUCTS</a>
            </div>
        </section>

        <section class="fv-collection-header">
            <h2 class="fv-collection-header__title">OUR COMPLETE<br>COLLECTION</h2>
        </section>

        <section class="fv-contact-cta">
            <div class="fv-contact-cta__bg">
                <img src="{{ asset('images/bgz.png') }}" alt="Floral Background" class="fv-contact-cta__img">
            </div>
            <div class="fv-contact-cta__card">
                <h3 class="fv-contact-cta__title">HAVE ANY QUESTIONS?</h3>
                <p class="fv-contact-cta__text">Drop us a line, and we'll get back to you as soon as we can.</p>
                <a href="{{ path('app_contact') }}" class="fv-contact-cta__link">CONTACT US</a>
            </div>
        </section>

        <section class="fv-quote">
            <div class="fv-quote__content">
                <h2 class="fv-quote__title">FLORALS FOR EVERY MOMENT</h2>
                <p class="fv-quote__text">From the simplest gesture to the grandest celebration, we create arrangements that speak when words aren't enough.</p>
            </div>
        </section>

        <section class="fv-features">
            <div class="fv-features__grid">
                <div class="fv-feature-item">
                    <div class="fv-feature-item__icon">
                        <svg viewBox="0 0 100 100" fill="none" stroke="white" stroke-width="1">
                            <path d="M50 85c0 0-25-15-25-35 0-15 10-25 25-25s25 10 25 25c0 20-25 35-25 35z" />
                            <path d="M50 25c-5 0-10 5-10 10s5 10 10 10 10-5 10-10-5-10-10-10z" />
                            <path d="M40 35c-5 0-10 5-10 10s5 10 10 10" />
                            <path d="M60 35c5 0 10 5 10 10s-5 10-10 10" />
                        </svg>
                    </div>
                    <h3 class="fv-feature-item__title">FRESH<br>&<br>PRIME</h3>
                    <p class="fv-feature-item__text">We use only the freshest blooms of the highest quality for your loved ones.</p>
                </div>
                <div class="fv-feature-item">
                    <div class="fv-feature-item__icon">
                        <svg viewBox="0 0 100 100" fill="none" stroke="white" stroke-width="1">
                            <path d="M50 20c-10 0-15 10-15 15s5 15 15 15 15-10 15-15-5-15-15-15z" />
                            <path d="M35 35c-10 0-15 10-15 15s5 15 15 15" />
                            <path d="M65 35c10 0 15 10 15 15s-5 15-15 15" />
                            <path d="M50 50c0 10-5 15-15 15s-15-5-15-15" />
                            <path d="M50 50c0 10 5 15 15 15s15-5 15-15" />
                        </svg>
                    </div>
                    <h3 class="fv-feature-item__title">TRUSTED<br>&<br>RENOWNED</h3>
                    <p class="fv-feature-item__text">Our florists are veterans in the industry with years of experience that fuel their creativity for every floral arrangement made just for you.</p>
                </div>
                <div class="fv-feature-item">
                    <div class="fv-feature-item__icon">
                        <svg viewBox="0 0 100 100" fill="none" stroke="white" stroke-width="1">
                            <circle cx="50" cy="50" r="30" />
                            <path d="M50 20c-5 5-10 15-10 30s5 25 10 30" />
                            <path d="M50 20c5 5 10 15 10 30s-5 25-10 30" />
                            <path d="M20 50c5-5 15-10 30-10s25 5 30 10" />
                            <path d="M20 50c5 5 15 10 30 10s25-5 30-10" />
                        </svg>
                    </div>
                    <h3 class="fv-feature-item__title">DEDICATED<br>&<br>METICULOUS</h3>
                    <p class="fv-feature-item__text">Our lines are open 24/7 - ask what you need anytime, anywhere, and our devoted sales executives will assist you with any of your floral needs.</p>
                </div>
            </div>
        </section>

        <section class="fv-who-we-are">
            <div class="fv-who-we-are__bg">
                <img src="{{ asset('images/fresh flower.png') }}" alt="Fresh Flowers Background" class="fv-who-we-are__img">
            </div>
            <div class="fv-who-we-are__card">
                <span class="fv-who-we-are__subtitle">WHO WE ARE</span>
                <p class="fv-who-we-are__text">
                    <strong>La Kurt's</strong> is the premier floral studio in the Philippines, creating fresh cut blooms, upscale floral arrangements, and novelty pieces for every moment and occasion.
                </p>
                <a href="{{ path('app_about') }}" class="fv-who-we-are__link">Tell Me More</a>
            </div>
        </section>

        <section class="fv-social-cta">
            <div class="fv-social-cta__content">
                <h2 class="fv-social-cta__title">AT LA KURT, WE MAKE EVERY MOMENT BLOOM.</h2>
                <p class="fv-social-cta__text">
                    Tag us on social media <strong>@lakurtph</strong>, and use our hashtag <strong>#LaKurtMoments</strong>. We'd love to hear your story!
                </p>
            </div>
        </section>
    </main>

    {% include 'client/footer.html.twig' %}
</div>
{% endif %}
{% endblock %}