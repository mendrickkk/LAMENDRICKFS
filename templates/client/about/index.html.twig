{% extends 'base.html.twig' %}

{% block title %}About Us - La Kurt Flowershop{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/client.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/about.css') }}">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
{% endblock %}

{% block body %}
<div class="fv-page">
    {% include 'client/_header.html.twig' %}

    <main class="fv-main">
        <section class="fv-about-page">
            <h1 class="fv-about-page__title">LA KURT FLOWERSHOP</h1>
            
            <div class="fv-about-page__image-wrapper">
                <img src="/images/bgz.png" alt="La Kurt Flowershop Studio" class="fv-about-page__image">
            </div>

            <div class="fv-about-page__content">
                <p>La Kurt Flowershop is the premier floral destination in the heart of the city, offering a curated selection of exquisite floral arrangements and bespoke botanical designs for all of life's cherished occasions.</p>

                <p>Our creations are crafted with passion and precision, brought to life by master florists with a deep love for nature's artistry. We source only the freshest, most vibrant blooms and the finest materials, ensuring every piece is a true masterpiece.</p>

                <p>From intimate hand-tied bouquets to luxurious centerpieces and grand event installations, our dedicated team goes above and beyond. We believe that every arrangement tells a story, uniquely tailored to express your deepest sentiments and make your loved ones feel truly special.</p>

                <p>We are proud to work closely with local growers and sustainable farms, nurturing a community that cultivates beauty with care. This commitment not only guarantees the unmatched freshness of our flowers but also supports the local artistry that makes our industry blossom.</p>

                <p class="fv-about-page__tagline">Here at La Kurt Flowershop, we make every moment bloom.</p>
            </div>
        </section>

        <section class="fv-team">
            <h2 class="fv-team__title">Meet the Team</h2>

            <div class="fv-team__ceo-split">
                <div class="fv-team__ceo-bg">
                    <img src="/images/bgz.png" alt="La Kurt Flowershop studio background" class="fv-team__ceo-bg-img">
                </div>

                <div class="fv-team__ceo-panel">
                    <div class="fv-team__ceo-photo-wrapper">
                        <img src="/images/CEO.png" alt="Kurt, Founder and CEO" class="fv-team__ceo-photo">
                    </div>

                    <div class="fv-team__ceo-info">
                        <h3 class="fv-team__ceo-name">Kurt</h3>
                        <p class="fv-team__ceo-position">Founder &amp; CEO</p>
                    </div>
                </div>
            </div>

            <div class="fv-team__grid">
                <div class="fv-team__member">
                    <div class="fv-team__member-image-wrapper">
                        <img src="/images/Giselle.png" alt="Giselle" class="fv-team__member-image">
                    </div>
                    <h3 class="fv-team__member-name">Giselle</h3>
                    <p class="fv-team__member-position">Events Coordinator</p>
                </div>

                <div class="fv-team__member">
                    <div class="fv-team__member-image-wrapper">
                        <img src="/images/karina.jpg" alt="Karina" class="fv-team__member-image">
                    </div>
                    <h3 class="fv-team__member-name">Karina</h3>
                    <p class="fv-team__member-position">Creative Director</p>
                </div>

                <div class="fv-team__member">
                    <div class="fv-team__member-image-wrapper">
                        <img src="/images/Nigel.png" alt="Nigel" class="fv-team__member-image">
                    </div>
                    <h3 class="fv-team__member-name">Nigel</h3>
                    <p class="fv-team__member-position">Operations Manager</p>
                </div>

                <div class="fv-team__member">
                    <div class="fv-team__member-image-wrapper">
                        <img src="/images/Winter.png" alt="Winter" class="fv-team__member-image">
                    </div>
                    <h3 class="fv-team__member-name">Winter</h3>
                    <p class="fv-team__member-position">Head Florist</p>
                </div>
            </div>
        </section>
    </main>

    {% include 'client/footer.html.twig' %}
</div>
{% endblock %}
