<div class="stock-view-panel">
    <div class="stock-form-section">
        <h3 class="stock-form-section-title">CATEGORY DETAILS</h3>
        <p class="stock-form-section-description">
            Category <strong>#{{ category.id }}</strong> — {{ category.name }}
        </p>

        <div class="stock-view-fields">
            <div class="stock-form-field">
                <label class="stock-form-label">Name</label>
                <p class="stock-form-static-value">{{ category.name }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Status</label>
                <p class="stock-form-static-value">
                    {% if category.isActive %}
                        <span class="badge badge-success">Active</span>
                    {% else %}
                        <span class="badge badge-danger">Inactive</span>
                    {% endif %}
                </p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Products</label>
                <p class="stock-form-static-value">{{ category.products|length }} product(s)</p>
            </div>
            <div class="stock-form-field stock-view-field-full">
                <label class="stock-form-label">Description</label>
                <p class="stock-form-static-value">{{ category.description ?: '—' }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Created</label>
                <p class="stock-form-static-value">{{ category.createdAt|date('M d, Y g:i A') }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Last updated</label>
                <p class="stock-form-static-value">{{ category.updatedAt|date('M d, Y g:i A') }}</p>
            </div>
            {% if category.createdBy %}
            <div class="stock-form-field">
                <label class="stock-form-label">Created by</label>
                <p class="stock-form-static-value">{{ category.createdBy.getFullName() }} ({{ category.createdBy.getRoleLabel() }})</p>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="stock-form-actions stock-view-modal-actions">
        <button
            type="button"
            class="stock-form-btn-primary"
            data-open-edit-category="{{ category.id }}"
            data-category-name="{{ category.name }}"
        >
            Edit category
        </button>
        <button type="button" class="stock-form-btn-cancel" data-modal-close="true">Close</button>
    </div>
</div>
