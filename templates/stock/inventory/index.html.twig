{% extends 'admin/layout.html.twig' %}

{% block title %}Flower Shop - Inventory{% endblock %}

{% block page_title %}{% endblock %}

{% block breadcrumb_current %}Inventory{% endblock %}

{% block breadcrumb %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block admin_content %}
    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div class="flash-message flash-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-messages">
            <div class="flash-message flash-error">
                <span>⚠</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    <div class="stock-management-container">
        <!-- Header Section -->
        <div class="stock-management-header">
            <h1 class="stock-management-title">Inventory Management</h1>
            <div class="stock-management-header-actions">
                <a href="javascript:history.back()" class="stock-back-circle-btn" title="Back">
                    <i class="fa fa-arrow-left"></i>
                </a>
                <a href="{{ path('app_inventory_new') }}" class="stock-new-entry-btn">
                    Add Inventory
                </a>
            </div>
        </div>

        <!-- Table Card -->
        <div class="card">
            <!-- Search and Filter Bar -->
            <div class="product-search-toolbar">
                <div class="search-input-container">
                    <i class="fa fa-search"></i>
                    <input type="text" placeholder="Search" id="inventorySearch">
                </div>
            </div>

            <div class="card-body card-body-no-padding">
                <div class="table-responsive product-table stock-table inventory-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Product Name</th>
                                <th>Quantity Added</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if inventories|length > 0 %}
                            {% for inventory in inventories %}
                                <tr class="stock-row" 
                                    data-product="{{ inventory.product.Name|lower }}"
                                    data-id="{{ inventory.id }}"
                                    data-quantity="{{ inventory.quantity }}"
                                    data-date="{{ inventory.createdAt|date('Y-m-d') }}">
                                    <td>#{{ inventory.id }}</td>
                                    <td><strong>{{ inventory.product.Name }}</strong></td>
                                    <td>
                                        <span class="product-price-text" style="color: #059669; font-weight: 600;">+{{ inventory.quantity }}</span>
                                    </td>
                                    <td>{{ inventory.createdAt|date('Y-m-d H:i') }}</td>
                                    <td>
                                        <div class="product-actions-cell">
                                            <a href="{{ path('app_inventory_show', {'id': inventory.id}) }}" 
                                               class="card-action-btn product-action-btn" 
                                               title="View">
                                                <i class="fa fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_inventory_edit', {'id': inventory.id}) }}" 
                                               class="card-action-btn product-action-btn product-action-btn-edit" 
                                               title="Edit">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                            <form method="post" action="{{ path('app_inventory_delete', {'id': inventory.id}) }}" 
                                                  style="display: inline-block; margin: 0;"
                                                  onsubmit="return confirm('Are you sure you want to delete this inventory record? This will reverse the stock quantity change.');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inventory.id) }}">
                                                <button type="submit" class="card-action-btn product-action-btn product-action-btn-delete" title="Delete">
                                                    <i class="fa fa-trash"></i>
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            <!-- Search Empty State (hidden by default) -->
                            <tr id="inventorySearchEmptyState" class="inventory-search-empty-state" style="display: none;">
                                <td colspan="5" class="stock-empty-state-cell">
                                    <div class="stock-empty-state-message">
                                        <i class="fa fa-search" style="font-size: 48px; color: #d1d5db; margin-bottom: 16px;"></i>
                                        <p style="font-size: 16px; color: #6b7280; margin: 0 0 8px 0;">No inventory records found matching your search.</p>
                                        <p style="font-size: 14px; color: #9ca3af; margin: 0;">Try searching with a different term or <a href="{{ path('app_inventory_new') }}" class="stock-empty-state-link">add a new inventory</a></p>
                                    </div>
                                </td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Search Functionality
            const searchInput = document.getElementById('inventorySearch');
            const inventoryRows = document.querySelectorAll('.stock-row');
            const searchEmptyState = document.getElementById('inventorySearchEmptyState');

            if (searchInput && inventoryRows.length > 0) {
                searchInput.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase().trim();
                    let visibleCount = 0;
                    
                    inventoryRows.forEach(row => {
                        // Skip the empty state row
                        if (row.classList.contains('inventory-search-empty-state')) {
                            return;
                        }
                        
                        const productName = row.getAttribute('data-product') || '';
                        const id = row.getAttribute('data-id') || '';
                        const quantity = row.getAttribute('data-quantity') || '';
                        const date = row.getAttribute('data-date') || '';
                        
                        // Search in multiple fields
                        const matchesSearch = searchTerm === '' || 
                            productName.includes(searchTerm) ||
                            id.includes(searchTerm) ||
                            quantity.includes(searchTerm) ||
                            date.includes(searchTerm);
                        
                        if (matchesSearch) {
                            row.style.display = '';
                            visibleCount++;
                        } else {
                            row.style.display = 'none';
                        }
                    });
                    
                    // Show/hide empty state based on search results
                    if (searchEmptyState) {
                        if (searchTerm !== '' && visibleCount === 0) {
                            searchEmptyState.style.display = '';
                        } else {
                            searchEmptyState.style.display = 'none';
                        }
                    }
                });
            }
        });
    </script>
{% endblock %}

