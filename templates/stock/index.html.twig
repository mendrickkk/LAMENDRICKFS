{% extends 'admin/layout.html.twig' %}

{% block title %}Flower Shop - Stocks{% endblock %}

{% block page_title %}{% endblock %}

{% block breadcrumb_current %}Stocks{% endblock %}

{% block breadcrumb %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block admin_content %}
    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div class="flash-message flash-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-messages">
            <div class="flash-message flash-error">
                <span>⚠</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    <div class="stock-management-container">
        <!-- Header Section -->
        <div class="stock-management-header">
            <h1 class="stock-management-title">Stock Management</h1>
            <div class="stock-management-header-actions">
                <button type="button" class="stock-new-entry-btn" id="openNewStockModal">
                    New Stock Entry
                </button>
            </div>
        </div>

        <!-- Table Card -->
        <div class="card">
            <!-- Search and Filter Bar -->
            <div class="product-search-toolbar">
                <div class="search-input-container">
                    <i class="fa fa-search"></i>
                    <input type="text" placeholder="Search" id="stockSearch">
                </div>
            </div>

            <div class="card-body card-body-no-padding">
                <div class="stock-bulk-actions" id="stockBulkActions" style="display: none; padding: 12px 16px; background: #f3f4f6; border-bottom: 1px solid #e5e7eb;">
                    <span id="selectedCount" style="font-weight: 600; color: #374151; margin-right: 16px;">0 selected</span>
                    <form method="post" action="{{ path('app_stock_bulk_delete') }}" id="bulkDeleteForm" onsubmit="return confirm('Are you sure you want to delete the selected stock entries?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('bulk_delete') }}">
                        <input type="hidden" name="ids" id="bulkDeleteIds">
                        <button type="submit" class="card-action-btn product-action-btn product-action-btn-delete" style="margin: 0;">
                            <i class="fa fa-trash"></i>
                            Delete Selected
                        </button>
                    </form>
                </div>
                <div class="table-responsive product-table stock-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th style="width: 40px;">
                                    <input type="checkbox" id="selectAllStocks" style="cursor: pointer;">
                                </th>
                                <th>ID</th>
                                <th>IMAGE</th>
                                <th>Product Name</th>
                                <th>Category</th>
                                <th>Price (₱)</th>
                                <th>Quantity</th>
                                <th>Created By</th>
                                <th>Created At</th>
                                <th>Updated At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if stocks|length > 0 %}
                            {% for stock in stocks %}
                                <tr class="stock-row" 
                                    data-product="{{ stock.product.Name|lower }}"
                                    data-category="{{ stock.product.category ? stock.product.category.name|lower : '' }}"
                                    data-id="{{ stock.id }}"
                                    data-price="{{ stock.product.price }}"
                                    data-quantity="{{ stock.quantity }}">
                                    <td>
                                        <input type="checkbox" class="stock-checkbox" value="{{ stock.id }}" style="cursor: pointer;">
                                    </td>
                                    <td>#{{ stock.id }}</td>
                                    <td>
                                        {% if stock.product.image %}
                                            <img src="{{ asset('uploads/products/' ~ stock.product.image) }}" 
                                                 alt="{{ stock.product.Name }}" 
                                                 class="table-product-image"
                                                 onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                            <div class="table-product-image-placeholder" style="display: none;">
                                                <i class="fa fa-image"></i>
                                            </div>
                                        {% else %}
                                            <div class="table-product-image-placeholder">
                                                <i class="fa fa-image"></i>
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td><strong>{{ stock.product.Name }}</strong></td>
                                    <td>
                                        {% if stock.product.category %}
                                            <span class="badge badge-info">{{ stock.product.category.name }}</span>
                                        {% else %}
                                            <span>-</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="product-price-text">₱{{ stock.product.price|number_format(2) }}</span>
                                    </td>
                                    <td>
                                        <span class="product-price-text">{{ stock.quantity }}</span>
                                    </td>
                                    <td>
                                        {% if stock.createdBy %}
                                            <div style="display: flex; flex-direction: column; gap: 2px;">
                                                <strong style="font-size: 13px; color: #374151;">{{ stock.createdBy.getFullName() }}</strong>
                                                <span style="font-size: 11px; color: #6b7280;">{{ stock.createdBy.getRoleLabel() }}</span>
                                            </div>
                                        {% else %}
                                            <span style="color: #9ca3af; font-style: italic;">-</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ stock.createdAt|date('Y-m-d') }}</td>
                                    <td>{{ stock.updatedAt|date('Y-m-d') }}</td>
                                    <td>
                                        <div class="product-actions-cell">
                                            <a href="{{ path('app_stock_show', {'id': stock.id}) }}" 
                                               class="card-action-btn product-action-btn"
                                               data-view-stock-modal="true"
                                               title="View">
                                                <i class="fa fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" 
                                               class="card-action-btn product-action-btn product-action-btn-edit"
                                               data-edit-stock-modal="true"
                                               title="Edit">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            <!-- Search Empty State (hidden by default) -->
                            <tr id="stockSearchEmptyState" class="stock-search-empty-state" style="display: none;">
                                <td colspan="11" class="stock-empty-state-cell">
                                    <div class="stock-empty-state-message">
                                        <i class="fa fa-search" style="font-size: 48px; color: #d1d5db; margin-bottom: 16px;"></i>
                                        <p style="font-size: 16px; color: #6b7280; margin: 0 0 8px 0;">No stock items found matching your search.</p>
                                        <p style="font-size: 14px; color: #9ca3af; margin: 0;">Try searching with a different term or <a href="{{ path('app_stock_new') }}" class="stock-empty-state-link">create a new stock entry</a></p>
                                    </div>
                                </td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- View Stock Modal -->
    <div class="admin-modal" id="viewStockModal" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="viewStockModalTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">STOCK MANAGEMENT</div>
                    <div class="admin-modal__title" id="viewStockModalTitle">Stock Details</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>
            <div class="admin-modal__body" id="viewStockModalBody"></div>
        </div>
    </div>

    <!-- Edit Stock Entry Modal -->
    <div class="admin-modal" id="editStockModal" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="editStockModalTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">STOCK MANAGEMENT</div>
                    <div class="admin-modal__title" id="editStockModalTitle">Edit Stock Entry</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <div class="admin-modal__body" id="editStockModalBody"></div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Bulk Selection Functionality
            const selectAllCheckbox = document.getElementById('selectAllStocks');
            const bulkActionsBar = document.getElementById('stockBulkActions');
            const selectedCountSpan = document.getElementById('selectedCount');
            const bulkDeleteForm = document.getElementById('bulkDeleteForm');
            const bulkDeleteIdsInput = document.getElementById('bulkDeleteIds');

            // Get visible checkboxes (not hidden by search filter)
            function getVisibleCheckboxes() {
                return Array.from(document.querySelectorAll('.stock-checkbox')).filter(checkbox => {
                    const row = checkbox.closest('.stock-row');
                    return row && row.style.display !== 'none';
                });
            }

            // Get all checkboxes
            function getAllCheckboxes() {
                return document.querySelectorAll('.stock-checkbox');
            }

            function updateBulkActions() {
                const checkedBoxes = document.querySelectorAll('.stock-checkbox:checked');
                const count = checkedBoxes.length;
                
                if (count > 0) {
                    bulkActionsBar.style.display = 'flex';
                    bulkActionsBar.style.alignItems = 'center';
                    selectedCountSpan.textContent = count + ' selected';
                    
                    // Update hidden input with selected IDs
                    const ids = Array.from(checkedBoxes).map(cb => cb.value);
                    bulkDeleteIdsInput.value = ids.join(',');
                } else {
                    bulkActionsBar.style.display = 'none';
                }

                // Update select all checkbox state based on visible checkboxes
                if (selectAllCheckbox) {
                    const visibleCheckboxes = getVisibleCheckboxes();
                    const visibleChecked = visibleCheckboxes.filter(cb => cb.checked);
                    
                    if (visibleCheckboxes.length === 0) {
                        selectAllCheckbox.checked = false;
                        selectAllCheckbox.indeterminate = false;
                    } else if (visibleChecked.length === visibleCheckboxes.length) {
                        selectAllCheckbox.checked = true;
                        selectAllCheckbox.indeterminate = false;
                    } else if (visibleChecked.length > 0) {
                        selectAllCheckbox.checked = false;
                        selectAllCheckbox.indeterminate = true;
                    } else {
                        selectAllCheckbox.checked = false;
                        selectAllCheckbox.indeterminate = false;
                    }
                }
            }

            // Select all checkbox - selects only visible checkboxes
            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    const visibleCheckboxes = getVisibleCheckboxes();
                    visibleCheckboxes.forEach(checkbox => {
                        checkbox.checked = this.checked;
                    });
                    updateBulkActions();
                });
            }

            // Individual checkboxes
            getAllCheckboxes().forEach(checkbox => {
                checkbox.addEventListener('change', updateBulkActions);
            });

            // Search Functionality
            const searchInput = document.getElementById('stockSearch');
            const stockRows = document.querySelectorAll('.stock-row');
            const searchEmptyState = document.getElementById('stockSearchEmptyState');

            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase().trim();
                    let visibleCount = 0;
                    
                    if (stockRows.length > 0) {
                        stockRows.forEach(row => {
                            // Skip the empty state row
                            if (row.classList.contains('stock-search-empty-state')) {
                                return;
                            }
                            
                            const productName = row.getAttribute('data-product') || '';
                            const category = row.getAttribute('data-category') || '';
                            const id = row.getAttribute('data-id') || '';
                            const price = row.getAttribute('data-price') || '';
                            const quantity = row.getAttribute('data-quantity') || '';
                            
                            // Search in multiple fields
                            const matchesSearch = searchTerm === '' || 
                                productName.includes(searchTerm) || 
                                category.includes(searchTerm) ||
                                id.toString().includes(searchTerm) ||
                                price.toString().includes(searchTerm) ||
                                quantity.toString().includes(searchTerm);
                            
                            if (matchesSearch) {
                                row.style.display = '';
                                visibleCount++;
                            } else {
                                row.style.display = 'none';
                            }
                        });
                    }
                    
                    // Show/hide empty state based on search results
                    if (searchEmptyState) {
                        if (searchTerm !== '' && visibleCount === 0 && stockRows.length > 0) {
                            searchEmptyState.style.display = '';
                        } else {
                            searchEmptyState.style.display = 'none';
                        }
                    }
                    
                    // Update select all state after filtering
                    updateBulkActions();
                });
            }

            // Initialize
            updateBulkActions();
        });
    </script>

    <!-- New Stock Entry Modal -->
    <div class="admin-modal" id="newStockModal" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="newStockModalTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">STOCK MANAGEMENT</div>
                    <div class="admin-modal__title" id="newStockModalTitle">New Stock Entry</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <div class="admin-modal__body" id="newStockModalBody">
                {{ include('stock/_form.html.twig', {
                    form: form,
                    button_label: 'Create Stock Entry',
                    action: path('app_stock_new'),
                    show_cancel: false
                }) }}
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const openBtn = document.getElementById('openNewStockModal');
            const modal = document.getElementById('newStockModal');
            const modalBody = document.getElementById('newStockModalBody');

            function openModal() {
                if (!modal) return;
                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');

                const firstInput = modal.querySelector('input, select, textarea, button');
                if (firstInput) firstInput.focus();
                initStockImageDropzone(modal);
            }

            function closeModal() {
                if (!modal) return;
                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
            }

            if (openBtn) {
                openBtn.addEventListener('click', function() {
                    openModal();
                });
            }

            if (modal) {
                modal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close="true"]')) {
                        closeModal();
                    }
                });

                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && modal.classList.contains('is-open')) {
                        closeModal();
                    }
                });
            }

            // AJAX submit (keeps list page visible)
            document.addEventListener('submit', async function(e) {
                const formEl = e.target;
                if (!modal || !modal.classList.contains('is-open')) return;
                if (!formEl || !formEl.matches('form[data-stock-form="true"]')) return;

                e.preventDefault();

                try {
                    const res = await fetch(formEl.action, {
                        method: 'POST',
                        body: new FormData(formEl),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (res.ok) {
                        const data = await res.json();
                        if (data && data.redirectUrl) {
                            window.location.href = data.redirectUrl;
                            return;
                        }
                        window.location.reload();
                        return;
                    }

                    // 422: validation errors - replace modal body with returned form HTML
                    const html = await res.text();
                    if (modalBody) {
                        modalBody.innerHTML = html;
                        initStockImageDropzone(modal);
                    }
                } catch (err) {
                    // fallback: allow normal submit if fetch fails
                    formEl.submit();
                }
            }, true);

            function initStockImageDropzone(rootEl) {
                const root = rootEl || document;
                const dropzone = root.querySelector('#imageDropzone');
                let fileInput = root.querySelector('#imageFileInput');
                if (!fileInput) fileInput = root.querySelector('input[type="file"][name*="productImage"]');
                const previewContainer = root.querySelector('#imagePreviewContainer');
                const preview = root.querySelector('#imagePreview');
                const removeBtn = root.querySelector('#imageRemoveBtn');

                if (!dropzone || !fileInput || !previewContainer || !preview) return;
                if (dropzone.dataset.bound === 'true') return;
                dropzone.dataset.bound = 'true';

                const preventDefaults = (e) => { e.preventDefault(); e.stopPropagation(); };

                ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                    dropzone.addEventListener(eventName, preventDefaults, false);
                });

                dropzone.addEventListener('click', function(e) {
                    if (e.target.closest('.image-remove-btn')) return;
                    fileInput.click();
                });

                dropzone.addEventListener('dragover', function() {
                    dropzone.classList.add('dragover');
                });

                dropzone.addEventListener('dragleave', function() {
                    dropzone.classList.remove('dragover');
                });

                dropzone.addEventListener('drop', function(e) {
                    dropzone.classList.remove('dragover');
                    const files = e.dataTransfer.files;
                    if (!files || files.length === 0) return;

                    const file = files[0];
                    const isImage = (file.type && file.type.startsWith('image/')) || /\.(jpg|jpeg|png|gif|bmp|webp|svg)$/i.test(file.name || '');
                    if (!isImage) {
                        alert('Please select an image file (JPG, PNG, GIF, etc.).');
                        return;
                    }

                    try {
                        const dt = new DataTransfer();
                        dt.items.add(file);
                        fileInput.files = dt.files;
                        fileInput.dispatchEvent(new Event('change', { bubbles: true }));
                    } catch (err) {
                        // ignore
                    }
                });

                fileInput.addEventListener('change', function() {
                    const file = this.files && this.files[0];
                    if (!file) return;

                    const isImage = (file.type && file.type.startsWith('image/')) || /\.(jpg|jpeg|png|gif|bmp|webp|svg)$/i.test(file.name || '');
                    if (!isImage) return;

                    const reader = new FileReader();
                    reader.onload = function(ev) {
                        preview.src = ev.target.result;
                        preview.style.display = 'block';
                        previewContainer.style.display = 'block';
                        dropzone.style.display = 'none';
                    };
                    reader.readAsDataURL(file);
                });

                if (removeBtn) {
                    removeBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        try {
                            const dt = new DataTransfer();
                            fileInput.files = dt.files;
                        } catch (err) {
                            fileInput.value = '';
                        }
                        preview.src = '';
                        previewContainer.style.display = 'none';
                        dropzone.style.display = 'block';
                    });
                }
            }

            const editModal = document.getElementById('editStockModal');
            const editModalBody = document.getElementById('editStockModalBody');
            const editLinks = document.querySelectorAll('a[data-edit-stock-modal="true"]');
            const viewModal = document.getElementById('viewStockModal');
            const viewModalBody = document.getElementById('viewStockModalBody');
            const viewLinks = document.querySelectorAll('a[data-view-stock-modal="true"]');

            function openEditModal() {
                if (!editModal) return;
                editModal.classList.add('is-open');
                editModal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
            }

            function closeEditModal() {
                if (!editModal) return;
                editModal.classList.remove('is-open');
                editModal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
                if (editModalBody) editModalBody.innerHTML = '';
            }

            function openViewModal() {
                if (!viewModal) return;
                viewModal.classList.add('is-open');
                viewModal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
            }

            function closeViewModal() {
                if (!viewModal) return;
                viewModal.classList.remove('is-open');
                viewModal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
                if (viewModalBody) viewModalBody.innerHTML = '';
            }

            viewLinks.forEach(link => {
                link.addEventListener('click', async function(ev) {
                    ev.preventDefault();
                    const url = this.getAttribute('href');
                    if (!url) return;

                    try {
                        const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await res.text();
                        if (viewModalBody) viewModalBody.innerHTML = html;
                        openViewModal();
                    } catch (err) {
                        window.location.href = url;
                    }
                });
            });

            if (viewModal) {
                viewModal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close="true"]')) closeViewModal();
                });
            }

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && viewModal && viewModal.classList.contains('is-open')) {
                    closeViewModal();
                }
            });

            editLinks.forEach(link => {
                link.addEventListener('click', async function(ev) {
                    ev.preventDefault();
                    const url = this.getAttribute('href');
                    if (!url) return;

                    try {
                        const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await res.text();
                        if (editModalBody) editModalBody.innerHTML = html;
                        openEditModal();
                        initStockImageDropzone(editModal);
                    } catch (err) {
                        window.location.href = url;
                    }
                });
            });

            if (editModal) {
                editModal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close="true"]')) closeEditModal();
                });
            }

            document.addEventListener('submit', async function(e) {
                const formEl = e.target;
                if (!editModal || !editModal.classList.contains('is-open')) return;
                if (!formEl || !formEl.matches('form[data-stock-form="true"]')) return;

                e.preventDefault();
                try {
                    const res = await fetch(formEl.action, {
                        method: 'POST',
                        body: new FormData(formEl),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (res.ok) {
                        const data = await res.json();
                        window.location.href = (data && data.redirectUrl) ? data.redirectUrl : window.location.href;
                        return;
                    }

                    const html = await res.text();
                    if (editModalBody) {
                        editModalBody.innerHTML = html;
                        initStockImageDropzone(editModal);
                    }
                } catch (err) {
                    formEl.submit();
                }
            }, true);
        });
    </script>
{% endblock %}

