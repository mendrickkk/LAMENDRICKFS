<form method="post" action="{{ path('app_stock_delete', {'id': stock.id}) }}" onsubmit="return confirm('🗑️ Are you sure you want to delete this stock?\n\nProduct: {{ stock.product.Name }}\nQuantity: {{ stock.quantity }}\nThis action cannot be undone!');" class="delete-form">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stock.id) }}">
    <button type="submit" class="btn btn-danger btn-small">🗑️ Delete</button>
</form>

