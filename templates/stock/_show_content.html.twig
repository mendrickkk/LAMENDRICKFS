<div class="stock-view-panel">
    <div class="stock-form-section">
        <h3 class="stock-form-section-title">STOCK DETAILS</h3>
        <p class="stock-form-section-description">
            Stock entry <strong>#{{ stock.id }}</strong> — {{ stock.product.Name }}
        </p>

        <div class="stock-view-fields">
            <div class="stock-form-field">
                <label class="stock-form-label">Product Name</label>
                <p class="stock-form-static-value">{{ stock.product.Name }}</p>
            </div>
            {% if stock.product.description %}
            <div class="stock-form-field stock-view-field-full">
                <label class="stock-form-label">Description</label>
                <p class="stock-form-static-value">{{ stock.product.description }}</p>
            </div>
            {% endif %}
            <div class="stock-form-field">
                <label class="stock-form-label">Price</label>
                <p class="stock-form-static-value">₱{{ stock.product.price|number_format(2) }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Category</label>
                <p class="stock-form-static-value">{{ stock.product.category ? stock.product.category.name : '—' }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Quantity</label>
                <p class="stock-form-static-value">{{ stock.quantity }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Created</label>
                <p class="stock-form-static-value">{{ stock.createdAt|date('M d, Y g:i A') }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Last updated</label>
                <p class="stock-form-static-value">{{ stock.updatedAt|date('M d, Y g:i A') }}</p>
            </div>
            {% if stock.createdBy %}
            <div class="stock-form-field">
                <label class="stock-form-label">Created by</label>
                <p class="stock-form-static-value">{{ stock.createdBy.getFullName() }} ({{ stock.createdBy.getRoleLabel() }})</p>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="stock-form-actions stock-view-modal-actions">
        <button
            type="button"
            class="stock-form-btn-primary"
            data-open-edit-stock="{{ stock.id }}"
            data-product-name="{{ stock.product.Name }}"
        >
            Edit entry
        </button>
        <button type="button" class="stock-form-btn-cancel" data-modal-close="true">Close</button>
    </div>
</div>
