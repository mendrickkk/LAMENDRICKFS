{% extends 'base.html.twig' %}

{% block title %}Register · La Kurt Flowershop{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/loginn.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/signupp.css') }}">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
{% endblock %}

{% block body %}
<div class="fv-page fv-login-page fv-register-page">
    {% include 'client/_header.html.twig' %}

    <main class="fv-main" role="main">
        <div class="fv-login fv-register">
            <h1 class="fv-login__title">REGISTER</h1>
            <p class="fv-login__lead">Please fill in the information below:</p>

            <div class="fv-login__alerts">
                {% for message in app.flashes('success') %}
                    <div class="fv-login__alert fv-login__alert--success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('warning') %}
                    <div class="fv-login__alert fv-login__alert--warning">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="fv-login__alert fv-login__alert--error">{{ message }}</div>
                {% endfor %}
            </div>

            <form method="post" action="{{ path('app_signup') }}" id="signupForm" class="fv-register__form" data-turbo="false">
                <div class="fv-login__field">
                    <input class="fv-login__input" type="text" id="first_name" name="first_name" value="{{ last_first_name|default('') }}" placeholder="First name" required autocomplete="given-name">
                </div>
                <div class="fv-login__field">
                    <input class="fv-login__input" type="text" id="last_name" name="last_name" value="{{ last_last_name|default('') }}" placeholder="Last name" required autocomplete="family-name">
                </div>
                <div class="fv-login__field">
                    <input class="fv-login__input" type="email" id="email" name="email" value="{{ last_email|default('') }}" placeholder="Email" required autocomplete="email">
                    <span class="fv-register__error" id="emailError" aria-live="polite"></span>
                </div>
                <div class="fv-login__field">
                    <input class="fv-login__input" type="text" id="username" name="username" value="{{ last_username|default('') }}" placeholder="Username" required autocomplete="username">
                    <span class="fv-register__error" id="usernameError" aria-live="polite"></span>
                </div>
                <div class="fv-login__field">
                    <div class="fv-login__password-wrap">
                        <input class="fv-login__input" type="password" id="password" name="password" placeholder="Password" required autocomplete="new-password">
                        <button type="button" class="fv-login__eye" id="togglePassword" aria-label="Show password">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <div class="fv-register__requirements" id="passwordRequirements" hidden>
                        <p class="fv-register__req-title">Password must have:</p>
                        <div class="fv-register__req-item" id="reqLength"><span class="fv-register__req-icon">×</span> At least 8 characters (required)</div>
                        <p class="fv-register__req-sub">And at least one of the following:</p>
                        <div class="fv-register__req-item" id="reqUppercase"><span class="fv-register__req-icon">×</span> One uppercase letter</div>
                        <div class="fv-register__req-item" id="reqLowercase"><span class="fv-register__req-icon">×</span> One lowercase letter</div>
                        <div class="fv-register__req-item" id="reqNumber"><span class="fv-register__req-icon">×</span> One number</div>
                        <div class="fv-register__req-item" id="reqSpecial"><span class="fv-register__req-icon">×</span> One special character (@$!%*?&amp;_)</div>
                    </div>
                    <span class="fv-register__error" id="passwordError" aria-live="polite"></span>
                </div>
                <div class="fv-login__field">
                    <div class="fv-login__password-wrap">
                        <input class="fv-login__input" type="password" id="confirm_password" name="confirm_password" placeholder="Confirm password" required autocomplete="new-password">
                        <button type="button" class="fv-login__eye" id="toggleConfirmPassword" aria-label="Show confirm password">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <span class="fv-register__error" id="confirmPasswordError" aria-live="polite"></span>
                </div>

                <label class="fv-register__terms">
                    <input type="checkbox" id="terms" name="terms" value="1" required>
                    <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
                </label>

                <div class="fv-login__divider" aria-hidden="true">
                    <span>OR</span>
                </div>

                <a href="{{ path('connect_google_start') }}" class="fv-login__google">
                    <span class="fv-login__google-icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21.6 12.25c0-.67-.06-1.3-.18-1.92H12v3.64h5.37c-.23 1.23-.91 2.28-1.94 2.98v2.41h3.13c1.83-1.68 2.9-4.15 2.9-7.11Z" fill="#4285F4"/>
                            <path d="M12 22c2.57 0 4.73-.85 6.31-2.31l-3.13-2.41c-.87.59-1.98.94-3.18.94-2.45 0-4.52-1.65-5.26-3.87H3.49v2.49C5.06 19.83 8.26 22 12 22Z" fill="#34A853"/>
                            <path d="M6.74 13.35c-.19-.59-.3-1.22-.3-1.87 0-.65.11-1.28.3-1.87V7.12H3.49A9.98 9.98 0 0 0 2 11.48c0 1.6.39 3.1 1.49 4.36l3.25-2.49Z" fill="#FBBC05"/>
                            <path d="M12 4.88c1.4 0 2.65.48 3.63 1.42l2.72-2.72C16.72 1.98 14.56 1 12 1 8.26 1 5.06 3.17 3.49 6.52l3.25 2.49c.74-2.22 2.81-3.87 5.26-3.87Z" fill="#EA4335"/>
                        </svg>
                    </span>
                    Continue with Google
                </a>

                <p class="fv-login__google-note">
                    Google sign-in is only for staff accounts.
                </p>

                <button type="submit" class="fv-login__submit fv-login__submit--register" id="createAccountBtn" disabled>CREATE MY ACCOUNT</button>

                <p class="fv-login__footer">
                    Already have an account? <a href="{{ path('app_login') }}">Log in</a>
                </p>
            </form>
        </div>
    </main>

    {% include 'client/footer.html.twig' %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('signupForm');
    const emailInput = document.getElementById('email');
    const usernameInput = document.getElementById('username');
    const passwordInput = document.getElementById('password');
    const confirmPasswordInput = document.getElementById('confirm_password');
    const passwordRequirements = document.getElementById('passwordRequirements');
    const togglePassword = document.getElementById('togglePassword');
    const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');
    const termsCheckbox = document.getElementById('terms');
    const createAccountBtn = document.getElementById('createAccountBtn');

    function validateEmail(email) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function showError(inputId, errorId, message) {
        const input = document.getElementById(inputId);
        const error = document.getElementById(errorId);
        if (input) input.classList.add('fv-register__input--error');
        if (error) { error.textContent = message || ''; }
    }

    function clearError(inputId, errorId) {
        const input = document.getElementById(inputId);
        const error = document.getElementById(errorId);
        if (input) input.classList.remove('fv-register__input--error');
        if (error) error.textContent = '';
    }

    function updatePasswordRequirements(password) {
        const checks = {
            length: password.length >= 8,
            uppercase: /[A-Z]/.test(password),
            lowercase: /[a-z]/.test(password),
            number: /[0-9]/.test(password),
            special: /[@$!%*?&_]/.test(password)
        };
        [['reqLength', checks.length], ['reqUppercase', checks.uppercase], ['reqLowercase', checks.lowercase], ['reqNumber', checks.number], ['reqSpecial', checks.special]].forEach(function(pair) {
            const el = document.getElementById(pair[0]);
            if (!el) return;
            el.classList.toggle('is-valid', pair[1]);
            const icon = el.querySelector('.fv-register__req-icon');
            if (icon) icon.textContent = pair[1] ? '✓' : '×';
        });
    }

    if (togglePassword && passwordInput) {
        togglePassword.addEventListener('click', function() {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            togglePassword.setAttribute('aria-label', type === 'password' ? 'Show password' : 'Hide password');
        });
    }
    if (toggleConfirmPassword && confirmPasswordInput) {
        toggleConfirmPassword.addEventListener('click', function() {
            const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            confirmPasswordInput.setAttribute('type', type);
        });
    }

    if (passwordInput && passwordRequirements) {
        passwordInput.addEventListener('focus', function() { passwordRequirements.hidden = false; });
        passwordInput.addEventListener('input', function() {
            passwordRequirements.hidden = false;
            updatePasswordRequirements(this.value);
            if (confirmPasswordInput.value && this.value !== confirmPasswordInput.value) {
                showError('confirm_password', 'confirmPasswordError', 'Passwords do not match');
            } else {
                clearError('confirm_password', 'confirmPasswordError');
            }
        });
    }

    if (emailInput) {
        emailInput.addEventListener('blur', function() {
            if (this.value && !validateEmail(this.value)) {
                showError('email', 'emailError', 'Please enter a valid email address');
            } else clearError('email', 'emailError');
        });
        emailInput.addEventListener('input', function() {
            if (this.value && validateEmail(this.value)) clearError('email', 'emailError');
        });
    }

    if (confirmPasswordInput && passwordInput) {
        confirmPasswordInput.addEventListener('input', function() {
            if (passwordInput.value && this.value !== passwordInput.value) {
                showError('confirm_password', 'confirmPasswordError', 'Passwords do not match');
            } else clearError('confirm_password', 'confirmPasswordError');
        });
    }

    if (form) {
        form.addEventListener('submit', function(e) {
            let ok = true;
            if (!validateEmail(emailInput.value)) {
                showError('email', 'emailError', 'Please enter a valid email address');
                ok = false;
            }
            const pw = passwordInput.value;
            const hasLen = pw.length >= 8;
            const hasOne = /[A-Z]/.test(pw) || /[a-z]/.test(pw) || /[0-9]/.test(pw) || /[@$!%*?&_]/.test(pw);
            if (!hasLen || !hasOne) {
                showError('password', 'passwordError', 'Password does not meet requirements');
                ok = false;
            } else clearError('password', 'passwordError');
            if (pw !== confirmPasswordInput.value) {
                showError('confirm_password', 'confirmPasswordError', 'Passwords do not match');
                ok = false;
            }
            if (!ok) e.preventDefault();
        });
    }

    if (termsCheckbox && createAccountBtn) {
        function updateBtn() { createAccountBtn.disabled = !termsCheckbox.checked; }
        termsCheckbox.addEventListener('change', updateBtn);
        updateBtn();
    }
});
</script>
{% endblock %}
