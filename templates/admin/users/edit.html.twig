{% extends 'admin/layout.html.twig' %}

{% block title %}Edit User - Flower Shop{% endblock %}

{% block page_title %}USER MANAGEMENT{% endblock %}

{% block breadcrumb %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block admin_content %}
    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div class="flash-message flash-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-messages">
            <div class="flash-message flash-error">
                <span>⚠</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    <div class="stock-entry-page">
        <div class="stock-entry-header">
            <div class="stock-entry-header-left">
                <div class="stock-entry-section-label">USER MANAGEMENT</div>
                <h1 class="stock-entry-title">Edit User: {{ user.username }}</h1>
            </div>
            <div class="stock-entry-header-right">
                <a href="{{ path('app_user_index') }}" class="stock-entry-back-btn">
                    <i class="fa fa-arrow-left"></i>
                    Back to list
                </a>
            </div>
        </div>

        <div class="stock-entry-form-container">
            {{ include('admin/users/_form.html.twig', {
                form: form,
                button_label: 'Update User',
                is_edit: true
            }) }}
        </div>
    </div>
{% endblock %}

