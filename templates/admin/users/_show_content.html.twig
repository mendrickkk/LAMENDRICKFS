<div class="stock-view-panel">
    <div class="stock-form-section">
        <h3 class="stock-form-section-title">USER DETAILS</h3>
        <p class="stock-form-section-description">
            User <strong>#{{ user.id }}</strong> — {{ user.fullName }} ({{ user.username }})
        </p>

        <div class="stock-view-fields">
            <div class="stock-form-field">
                <label class="stock-form-label">Full name</label>
                <p class="stock-form-static-value">{{ user.fullName }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Username</label>
                <p class="stock-form-static-value">{{ user.username }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Email</label>
                <p class="stock-form-static-value">{{ user.email }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Role</label>
                <p class="stock-form-static-value">
                    {% if user.role == 'ROLE_ADMIN' %}
                        <span class="badge" style="background: #dc2626; color: white; padding: 4px 10px; border-radius: 12px; font-size: 12px;">Admin</span>
                    {% elseif user.role == 'ROLE_STAFF' %}
                        <span class="badge" style="background: #2563eb; color: white; padding: 4px 10px; border-radius: 12px; font-size: 12px;">Staff</span>
                    {% else %}
                        <span class="badge" style="background: #059669; color: white; padding: 4px 10px; border-radius: 12px; font-size: 12px;">Client</span>
                    {% endif %}
                </p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Status</label>
                <p class="stock-form-static-value">
                    {% if user.isActive %}
                        <span class="badge" style="background: #dcfce7; color: #166534; padding: 4px 10px; border-radius: 12px; font-size: 12px;"><i class="fa fa-check-circle"></i> Active</span>
                    {% else %}
                        <span class="badge" style="background: #fee2e2; color: #991b1b; padding: 4px 10px; border-radius: 12px; font-size: 12px;"><i class="fa fa-times-circle"></i> Inactive</span>
                    {% endif %}
                </p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Created</label>
                <p class="stock-form-static-value">{{ user.createdAt ? user.createdAt|date('M d, Y g:i A') : '—' }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Last updated</label>
                <p class="stock-form-static-value">{{ user.updatedAt ? user.updatedAt|date('M d, Y g:i A') : '—' }}</p>
            </div>
            <div class="stock-form-field">
                <label class="stock-form-label">Created by</label>
                <p class="stock-form-static-value">{{ user.createdBy ? user.createdBy.username : 'Self-registered' }}</p>
            </div>
        </div>
    </div>

    <div class="stock-form-actions stock-view-modal-actions">
        <button
            type="button"
            class="stock-form-btn-primary"
            data-open-edit-user="{{ user.id }}"
            data-user-name="{{ user.username }}"
        >
            Edit user
        </button>
        <button type="button" class="stock-form-btn-cancel" data-modal-close="true">Close</button>
    </div>
</div>
