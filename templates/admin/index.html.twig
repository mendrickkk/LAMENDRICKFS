{% extends 'admin/layout.html.twig' %}

{% block title %}Hello AdminPanelController!{% endblock %}

{% block page_title %}Dashboard{% endblock %}

{% block breadcrumb_current %}Dashboard{% endblock %}

{% block admin_content %}
    <!-- Stats -->
    <div class="stats-grid"
         data-admin-metrics-stream-url="{{ path('app_admin_stream_metrics') }}"
         data-admin-metrics-url="{{ path('app_admin_realtime_metrics') }}">
        <a href="{{ path('app_orders') }}" class="stat-card-link">
            <div class="stat-card stat-card-pink">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Total Orders</div>
                        <div class="stat-card-value" id="metricTotalOrders">{{ totalOrders|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-pink">
                        <i class="fa fa-receipt"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">View all →</div>
                </div>
            </div>
        </a>

        {% if isAdmin %}
        <a href="{{ path('app_orders') }}" class="stat-card-link">
            <div class="stat-card stat-card-green">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Revenue</div>
                        <div class="stat-card-value" id="metricRevenue">₱ {{ totalRevenue|number_format(2, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-green">
                        <i class="fa fa-peso-sign"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    {% if revenueChange > 0 %}
                        <div class="stat-trend stat-trend-up">
                            <i class="fa fa-arrow-up"></i>
                            {{ revenueChange }}%
                        </div>
                    {% elseif revenueChange < 0 %}
                        <div class="stat-trend stat-trend-down">
                            <i class="fa fa-arrow-down"></i>
                            {{ revenueChange|abs }}%
                        </div>
                    {% else %}
                        <div class="stat-trend">
                            <i class="fa fa-minus"></i>
                            0%
                        </div>
                    {% endif %}
                    <div class="stat-period">this month</div>
                </div>
            </div>
        </a>

        <a href="{{ path('app_user_index') }}" class="stat-card-link">
            <div class="stat-card stat-card-blue">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Total Users</div>
                        <div class="stat-card-value" id="metricTotalUsers">{{ totalUsers|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-blue">
                        <i class="fa fa-users"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">Manage users →</div>
                </div>
            </div>
        </a>

        <a href="{{ path('app_user_index') }}" class="stat-card-link">
            <div class="stat-card stat-card-orange">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Total Staff</div>
                        <div class="stat-card-value" id="metricTotalStaff">{{ totalStaff|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-orange">
                        <i class="fa fa-user-tie"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">Manage staff →</div>
                </div>
            </div>
        </a>
        {% endif %}

        <a href="{{ path('app_stock_index') }}" class="stat-card-link">
            <div class="stat-card stat-card-purple">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Low Stock</div>
                        <div class="stat-card-value" id="metricLowStock">{{ lowStockCount|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-purple">
                        <i class="fa fa-box"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">Manage →</div>
                </div>
            </div>
        </a>

        <a href="{{ path('app_category_index') }}" class="stat-card-link">
            <div class="stat-card stat-card-blue">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Categories</div>
                        <div class="stat-card-value" id="metricCategories">{{ totalCategories|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-blue">
                        <i class="fa fa-tags"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">Manage →</div>
                </div>
            </div>
        </a>

        <a href="{{ path('app_product_index') }}" class="stat-card-link">
            <div class="stat-card stat-card-green">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Products</div>
                        <div class="stat-card-value" id="metricProducts">{{ totalProducts|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-green">
                        <i class="fa fa-box-open"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">View all →</div>
                </div>
            </div>
        </a>

        <a href="{{ path('app_stock_index') }}" class="stat-card-link">
            <div class="stat-card stat-card-pink">
                <div class="stat-card-header">
                    <div class="stat-card-info">
                        <div class="stat-card-label">Stocks</div>
                        <div class="stat-card-value" id="metricStocks">{{ totalStocks|number_format(0, '.', ',') }}</div>
                    </div>
                    <div class="stat-card-icon stat-card-icon-pink">
                        <i class="fa fa-warehouse"></i>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <div class="stat-card-link-text">Manage →</div>
                </div>
            </div>
        </a>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const grid = document.querySelector('.stats-grid');
            if (!grid) return;

            const streamUrl = grid.getAttribute('data-admin-metrics-stream-url');
            const metricsUrl = grid.getAttribute('data-admin-metrics-url');

            const els = {
                totalOrders: document.getElementById('metricTotalOrders'),
                revenue: document.getElementById('metricRevenue'),
                totalUsers: document.getElementById('metricTotalUsers'),
                totalStaff: document.getElementById('metricTotalStaff'),
                lowStock: document.getElementById('metricLowStock'),
                categories: document.getElementById('metricCategories'),
                products: document.getElementById('metricProducts'),
                stocks: document.getElementById('metricStocks'),
            };

            let source = null;
            let pollTimer = null;
            let inflight = false;

            function startPollingFallback() {
                if (pollTimer !== null) return;
                pollTimer = window.setInterval(fetchAndApplyMetrics, 60000);
            }

            function stopPollingFallback() {
                if (pollTimer === null) return;
                window.clearInterval(pollTimer);
                pollTimer = null;
            }

            function closeStream() {
                if (!source) return;
                try { source.close(); } catch (e) {}
                source = null;
            }

            function formatInt(value) {
                const n = Number(value || 0);
                return n.toLocaleString(undefined, { maximumFractionDigits: 0 });
            }

            function formatMoney(value) {
                const n = Number(value || 0);
                return '₱ ' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function applyMetrics(metrics) {
                if (!metrics || typeof metrics !== 'object') return;

                if (els.totalOrders) els.totalOrders.textContent = formatInt(metrics.totalOrders);
                if (els.lowStock) els.lowStock.textContent = formatInt(metrics.lowStockCount);
                if (els.categories) els.categories.textContent = formatInt(metrics.totalCategories);
                if (els.products) els.products.textContent = formatInt(metrics.totalProducts);
                if (els.stocks) els.stocks.textContent = formatInt(metrics.totalStocks);

                // Admin-only cards (may not exist in DOM for staff)
                if (els.revenue && metrics.totalRevenue !== null && metrics.totalRevenue !== undefined) {
                    els.revenue.textContent = formatMoney(metrics.totalRevenue);
                }
                if (els.totalUsers && metrics.totalUsers !== null && metrics.totalUsers !== undefined) {
                    els.totalUsers.textContent = formatInt(metrics.totalUsers);
                }
                if (els.totalStaff && metrics.totalStaff !== null && metrics.totalStaff !== undefined) {
                    els.totalStaff.textContent = formatInt(metrics.totalStaff);
                }
            }

            async function fetchAndApplyMetrics() {
                if (!metricsUrl || inflight) return;
                inflight = true;
                try {
                    const res = await fetch(metricsUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (!res.ok) return;
                    const data = await res.json();
                    applyMetrics(data && data.metrics ? data.metrics : null);
                } catch (e) {
                    // ignore
                } finally {
                    inflight = false;
                }
            }

            function connectStream() {
                if (!streamUrl || typeof window.EventSource !== 'function') {
                    startPollingFallback();
                    return;
                }

                // Keep a single long-lived connection; EventSource will auto-reconnect if it drops.
                closeStream();
                source = new EventSource(streamUrl, { withCredentials: true });

                source.addEventListener('open', function () {
                    stopPollingFallback();
                });

                source.addEventListener('metrics-changed', function () {
                    fetchAndApplyMetrics();
                });

                source.onerror = function () {
                    startPollingFallback();
                    // No manual reconnect loop here — EventSource handles it.
                };
            }

            connectStream();
            // Always sync immediately so no manual refresh is needed.
            fetchAndApplyMetrics();
            startPollingFallback();

            // Fix "needs one refresh" when returning via Back button (bfcache) or switching tabs.
            window.addEventListener('pageshow', function () {
                connectStream();
                fetchAndApplyMetrics();
            });
            document.addEventListener('visibilitychange', function () {
                if (document.visibilityState === 'visible') {
                    fetchAndApplyMetrics();
                }
            });
        });
    </script>

    <!-- Recent Activity & Orders Row -->
    <div class="row" style="margin-top: 20px;">
        <!-- Recent Orders Table -->
        <div class="col-md-7">
            <div class="card">
                <div class="card-header">
                    <div class="card-title">
                        <i class="fa fa-receipt"></i>
                        Recent Orders
                    </div>
                    <div class="card-actions">
                        <a href="{{ path('app_orders') }}" class="card-action-btn">
                            <i class="fa fa-external-link"></i>
                            View All
                        </a>
                    </div>
                </div>
                <div class="card-body card-body-no-padding">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Order #</th>
                                    <th>Customer</th>
                                    <th>Status</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if recentOrders|length > 0 %}
                                    {% for order in recentOrders %}
                                        <tr>
                                            <td>#{{ order.orderNumber }}</td>
                                            <td>{{ order.customerName }}</td>
                                            <td>
                                                <span class="status-badge status-{{ order.status|lower }}">
                                                    <span class="status-badge-dot"></span>
                                                    {{ order.status }}
                                                </span>
                                            </td>
                                            <td>₱ {{ order.total|number_format(2, '.', ',') }}</td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="4" style="text-align: center; padding: 40px; color: #6b7280;">
                                            No orders found
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity Logs (Admin only) -->
        {% if isAdmin %}
        <div class="col-md-5">
            <div class="card">
                <div class="card-header">
                    <div class="card-title">
                        <i class="fa fa-history"></i>
                        Recent Activity
                    </div>
                    <div class="card-actions">
                        <a href="{{ path('app_activity_log_index') }}" class="card-action-btn">
                            <i class="fa fa-external-link"></i>
                            View Logs
                        </a>
                    </div>
                </div>
                <div class="card-body card-body-no-padding">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if recentActivities is defined and recentActivities|length > 0 %}
                                    {% for activity in recentActivities %}
                                        <tr>
                                            <td>
                                                <strong>{{ activity.username }}</strong>
                                                <div style="font-size: 11px; color: #6b7280;">{{ activity.role|replace({'ROLE_': ''})|title }}</div>
                                            </td>
                                            <td>
                                                <span class="badge-action badge-{{ activity.action|lower }}" 
                                                      style="padding: 2px 6px; font-size: 10px; border-radius: 4px; 
                                                      {% if activity.action == 'CREATE' %}background-color: #dcfce7; color: #16a34a;
                                                      {% elseif activity.action == 'UPDATE' %}background-color: #e0f2fe; color: #0284c7;
                                                      {% elseif activity.action == 'DELETE' %}background-color: #fee2e2; color: #dc2626;
                                                      {% else %}background-color: #f3f4f6; color: #4b5563;{% endif %}">
                                                    {{ activity.actionLabel }}
                                                </span>
                                                <div style="font-size: 11px; color: #6b7280; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                    {{ activity.targetEntity }}
                                                </div>
                                            </td>
                                            <td style="font-size: 12px; white-space: nowrap;">
                                                {{ activity.createdAt|date('M d, H:i') }}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="3" style="text-align: center; padding: 40px; color: #6b7280;">
                                            No recent activity
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
{% endblock %}
