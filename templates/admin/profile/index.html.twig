{% extends 'admin/layout.html.twig' %}

{% block title %}My Profile - Flower Shop{% endblock %}

{% block admin_content %}
    <div class="admin-profile">
    <div class="profile-container">
        <!-- Left Column: Profile Overview -->
        <div class="profile-left">
            <div class="card profile-overview">
                <div class="profile-overview-header">
                    <div class="profile-overview-avatar">
                        {{ user.username|slice(0, 1)|upper }}
                    </div>
                    <div class="profile-overview-name">{{ user.getFullName() }}</div>
                    <div class="profile-overview-role">{{ user.getRoleLabel() }}</div>
                    <div class="profile-overview-email">{{ user.email }}</div>
                </div>

                <div class="profile-overview-details">
                    <div class="profile-detail-row">
                        <span class="profile-detail-label">User ID</span>
                        <span class="profile-detail-value">#{{ user.id }}</span>
                    </div>
                    <div class="profile-detail-row">
                        <span class="profile-detail-label">Username</span>
                        <span class="profile-detail-value">{{ user.username }}</span>
                    </div>
                    <div class="profile-detail-row">
                        <span class="profile-detail-label">Status</span>
                        <span class="profile-detail-value">
                            {% if user.isActive %}
                                <span class="badge badge-success">Active</span>
                            {% else %}
                                <span class="badge badge-danger">Inactive</span>
                            {% endif %}
                        </span>
                    </div>
                    <div class="profile-detail-row">
                        <span class="profile-detail-label">Created At</span>
                        <span class="profile-detail-value">{{ user.createdAt|date('Y-m-d') }}</span>
                    </div>
                    <div class="profile-detail-row">
                        <span class="profile-detail-label">Last Updated</span>
                        <span class="profile-detail-value">{{ user.updatedAt|date('Y-m-d') }}</span>
                    </div>
                    <div class="profile-detail-row">
                        <span class="profile-detail-label">Created By</span>
                        <span class="profile-detail-value">
                            {% if user.createdBy %}
                                {{ user.createdBy.username }}
                            {% else %}
                                System
                            {% endif %}
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Edit Forms -->
        <div class="profile-right">
            <div class="flash-messages">
                {% for message in app.flashes('success') %}
                    <div class="flash-message flash-success">
                        <i class="fa fa-check-circle"></i> {{ message }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-message flash-error">
                        <i class="fa fa-exclamation-circle"></i> {{ message }}
                    </div>
                {% endfor %}
            </div>

            <!-- Edit Profile Form -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">
                        <i class="fa fa-user-edit"></i> Edit Profile Information
                    </div>
                </div>
                <div class="card-body">
                    {{ form_start(profileForm) }}
                        <div class="profile-form-grid">
                            <div class="form-group">
                                {{ form_label(profileForm.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(profileForm.firstName, {'attr': {'class': 'form-input'}}) }}
                                {{ form_errors(profileForm.firstName) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(profileForm.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(profileForm.lastName, {'attr': {'class': 'form-input'}}) }}
                                {{ form_errors(profileForm.lastName) }}
                            </div>
                        </div>
                        <div class="form-group">
                            {{ form_label(profileForm.username, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(profileForm.username, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(profileForm.username) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(profileForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(profileForm.email, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(profileForm.email) }}
                        </div>
                        <div class="profile-form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-save"></i> Save Changes
                            </button>
                        </div>
                    {{ form_end(profileForm) }}
                </div>
            </div>

            <!-- Change Password Form -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">
                        <i class="fa fa-lock"></i> Change Password
                    </div>
                </div>
                <div class="card-body">
                    {{ form_start(passwordForm) }}
                        <div class="form-group">
                            {{ form_label(passwordForm.currentPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(passwordForm.currentPassword, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(passwordForm.currentPassword) }}
                        </div>
                        <div class="profile-form-grid">
                            <div class="form-group">
                                {{ form_label(passwordForm.newPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(passwordForm.newPassword, {'attr': {'class': 'form-input'}}) }}
                                {{ form_errors(passwordForm.newPassword) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(passwordForm.confirmPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(passwordForm.confirmPassword, {'attr': {'class': 'form-input'}}) }}
                                {{ form_errors(passwordForm.confirmPassword) }}
                            </div>
                        </div>
                        <div class="profile-form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-key"></i> Change Password
                            </button>
                        </div>
                    {{ form_end(passwordForm) }}
                </div>
            </div>
        </div>
    </div>
    </div>
{% endblock %}

