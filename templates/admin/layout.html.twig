{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="{{ path('app_admin') }}" class="sidebar-brand">
                <div class="sidebar-logo">
                    <img src="{{ asset('img/weblogoz.png') }}" alt="Logo" class="logo-image">
                </div>
                <div class="sidebar-logo-text">FlowerShop</div>
            </a>
            <button class="sidebar-toggle" aria-label="Toggle sidebar">
                <i class="fa fa-bars"></i>
            </button>
        </div>

        <nav class="sidebar-menu">
            <div class="menu-section">
                <div class="menu-section-title">Overview</div>
                <a class="menu-item {% if app.request.attributes.get('_route') == 'app_admin' %}menu-item-active{% endif %}" href="{{ path('app_admin') }}">
                    <i class="fa fa-gauge menu-item-icon"></i>
                    Dashboard
                </a>
                <a class="menu-item {% if 'app_product' in app.request.attributes.get('_route') %}menu-item-active{% endif %}" href="{{ path('app_product_index') }}">
                    <i class="fa fa-box menu-item-icon"></i>
                    Product
                </a>
                <a class="menu-item {% if app.request.attributes.get('_route') == 'app_orders' %}menu-item-active{% endif %}" href="{{ path('app_orders') }}">
                    <i class="fa fa-receipt menu-item-icon"></i>
                    Orders
                </a>
                <a class="menu-item {% if 'app_stock' in app.request.attributes.get('_route') %}menu-item-active{% endif %}" href="{{ path('app_stock_index') }}">
                    <i class="fa fa-warehouse menu-item-icon"></i>
                    Stocks
                </a>
                <a class="menu-item {% if 'app_category' in app.request.attributes.get('_route') %}menu-item-active{% endif %}" href="{{ path('app_category_index') }}">
                    <i class="fa fa-tags menu-item-icon"></i>
                    Category
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <a class="menu-item {% if 'app_user' in app.request.attributes.get('_route') %}menu-item-active{% endif %}" href="{{ path('app_user_index') }}">
                    <i class="fa fa-users menu-item-icon"></i>
                    User Management
                </a>
                <a class="menu-item {% if 'app_activity_log' in app.request.attributes.get('_route') %}menu-item-active{% endif %}" href="{{ path('app_activity_log_index') }}">
                    <i class="fa fa-history menu-item-icon"></i>
                    Activity Logs
                </a>
                {% endif %}
            </div>
        </nav>

        <div class="sidebar-footer">
            {% if app.user %}
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">{{ app.user.userIdentifier|first|upper }}</div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">{{ app.user.userIdentifier }}</div>
                    <div class="sidebar-user-role">
                        {% if app.user.roleLabel is defined %}
                            {{ app.user.roleLabel }}
                        {% elseif app.user.role is defined %}
                            {{ app.user.role|replace({'ROLE_': ''})|title }}
                        {% else %}
                            {{ app.user.roles[0]|replace({'ROLE_': ''})|title }}
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </aside>

    <!-- Main content -->
    <main class="main-content">
        <header class="top-header">
            <div class="header-container">
                <div class="header-left">
                    <button class="mobile-menu-btn" aria-label="Open menu">
                        <i class="fa fa-bars"></i>
                    </button>
                    <h1 class="page-title">{% block page_title %}Dashboard{% endblock %}</h1>
                </div>
                <div class="header-search">
                    <input class="search-input" placeholder="Search..." />
                    <i class="fa fa-search search-icon"></i>
                </div>
                <div class="header-actions">
                    <button class="header-action-btn" aria-label="Notifications">
                        <i class="fa fa-bell"></i>
                    </button>
                    
                    <!-- Account Dropdown -->
                    {% if app.user %}
                    <div class="account-dropdown">
                        <button class="account-dropdown-toggle" aria-label="Account Menu">
                            <div class="account-avatar">{{ app.user.userIdentifier|first|upper }}</div>
                            <div class="account-info">
                                <div class="account-name">{{ app.user.userIdentifier }}</div>
                                <div class="account-role">
                                    {% if app.user.roleLabel is defined %}
                                        {{ app.user.roleLabel }}
                                    {% elseif app.user.role is defined %}
                                        {{ app.user.role|replace({'ROLE_': ''})|title }}
                                    {% else %}
                                        {{ app.user.roles[0]|replace({'ROLE_': ''})|title }}
                                    {% endif %}
                                </div>
                            </div>
                            <i class="fa fa-chevron-down account-dropdown-arrow"></i>
                        </button>
                        
                        <div class="account-menu">
                            <div class="account-menu-header">
                                <div class="account-menu-user">
                                    <div class="account-menu-avatar">{{ app.user.userIdentifier|first|upper }}</div>
                                    <div class="account-menu-info">
                                        <div class="account-menu-name">{{ app.user.userIdentifier }}</div>
                                        <div class="account-menu-role">
                                            {% if app.user.roleLabel is defined %}
                                                {{ app.user.roleLabel }}
                                            {% elseif app.user.role is defined %}
                                                {{ app.user.role|replace({'ROLE_': ''})|title }}
                                            {% else %}
                                                {{ app.user.roles[0]|replace({'ROLE_': ''})|title }}
                                            {% endif %}
                                        </div>
                                        <div class="account-menu-email">
                                            {% if app.user.email is defined %}
                                                {{ app.user.email }}
                                            {% else %}
                                                {{ app.user.userIdentifier }}@flowershop.com
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="account-menu-body">
                                <a href="{{ path('app_profile') }}" class="account-menu-item">
                                    <i class="fa fa-user"></i>
                                    My Profile
                                </a>
                                <a href="{{ path('app_settings_index') }}" class="account-menu-item">
                                    <i class="fa fa-cog"></i>
                                    Account Settings
                                </a>
                                
                                <div class="account-menu-divider"></div>
                                
                                <a href="#" class="account-menu-item">
                                    <i class="fa fa-question-circle"></i>
                                    Help & Support
                                </a>
                                <a href="#" class="account-menu-item">
                                    <i class="fa fa-info-circle"></i>
                                    About
                                </a>
                            </div>
                            
                            <div class="account-menu-footer">
                                <form method="post" action="{{ path('app_logout') }}" style="margin: 0; padding: 0;">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                    <button type="submit" class="account-logout-btn">
                                        <i class="fa fa-sign-out"></i>
                                        Sign Out
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </header>

        <section class="dashboard-container">
            {% block breadcrumb %}
            <nav class="breadcrumb">
                <span class="breadcrumb-item">
                    <a class="breadcrumb-link" href="{{ path('app_admin') }}">Home</a>
                </span>
                <span class="breadcrumb-separator">/</span>
                <span class="breadcrumb-current">{% block breadcrumb_current %}Dashboard{% endblock %}</span>
            </nav>
            {% endblock %}

            {% block admin_content %}{% endblock %}
        </section>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Account dropdown functionality
    const accountDropdown = document.querySelector('.account-dropdown');
    const accountToggle = document.querySelector('.account-dropdown-toggle');
    const accountMenu = document.querySelector('.account-menu');
    
    if (accountToggle && accountMenu) {
        // Ensure toggle button is always clickable
        accountToggle.style.pointerEvents = 'auto';
        accountToggle.style.cursor = 'pointer';
        accountToggle.style.zIndex = '10001';
        
        // Toggle dropdown on click
        accountToggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            accountDropdown.classList.toggle('open');
        }, true); // Use capture phase
        
        // Also handle mousedown for better responsiveness
        accountToggle.addEventListener('mousedown', function(e) {
            e.preventDefault();
            e.stopPropagation();
        }, true);
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (accountDropdown && !accountDropdown.contains(e.target)) {
                accountDropdown.classList.remove('open');
            }
        }, true);
        
        // Close dropdown on escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && accountDropdown) {
                accountDropdown.classList.remove('open');
            }
        });
        
        // Handle menu item clicks
        const menuItems = document.querySelectorAll('.account-menu-item');
        menuItems.forEach(item => {
            item.style.pointerEvents = 'auto';
            item.style.cursor = 'pointer';
            item.style.zIndex = '10003';
            
            item.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                console.log('Menu item clicked:', this.textContent.trim(), 'href:', href);
                
                // Only prevent default if it's a hash link (#)
                if (href && href !== '#' && !href.startsWith('#')) {
                    // Allow normal navigation for actual links
                    accountDropdown.classList.remove('open');
                    // Let the browser handle the navigation
                    return true;
                } else {
                    // Prevent default only for placeholder links
                    e.preventDefault();
                    e.stopPropagation();
                    accountDropdown.classList.remove('open');
                }
            }, true);
        });
        
        // Handle logout button - ensure it's always clickable
        const logoutBtn = document.querySelector('.account-logout-btn');
        if (logoutBtn) {
            logoutBtn.style.pointerEvents = 'auto';
            logoutBtn.style.cursor = 'pointer';
            logoutBtn.style.zIndex = '10004';
            
            logoutBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();
                
                // Confirm logout
                if (confirm('Are you sure you want to sign out?')) {
                    // Submit the logout form
                    const form = logoutBtn.closest('form');
                    if (form) {
                        form.submit();
                    }
                }
            }, true);
            
            // Also handle mousedown for better responsiveness
            logoutBtn.addEventListener('mousedown', function(e) {
                e.preventDefault();
                e.stopPropagation();
            }, true);
        }
    }
    
    // Mobile menu functionality
    const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
    const sidebar = document.querySelector('.sidebar');
    
    if (mobileMenuBtn && sidebar) {
        mobileMenuBtn.addEventListener('click', function() {
            sidebar.classList.toggle('sidebar-mobile-open');
        });
    }
    
    // Sidebar toggle functionality (hide brand only)
    const sidebarToggle = document.querySelector('.sidebar-toggle');
    
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', function() {
            document.body.classList.toggle('sidebar-hide-brand');
        });
    }
});
</script>
{% endblock %}
