{% extends 'admin/layout.html.twig' %}

{% block title %}Flower Shop - Products{% endblock %}

{% block page_title %}Products{% endblock %}

{% block breadcrumb_current %}Products{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block admin_content %}
    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div class="flash-message flash-success">
                <span>✓</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-messages">
            <div class="flash-message flash-error">
                <span>⚠</span>
                <span>{{ message }}</span>
            </div>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <i class="fa fa-box"></i>
                Products
            </div>
            <div class="card-actions">
                <button type="button" class="card-action-btn product-new-btn" id="openNewStockModalFromProducts">
                    <i class="fa fa-plus"></i>
                    Add via Stocks
                </button>
            </div>
        </div>

        <!-- Search and Filter Bar -->
        <div class="product-search-toolbar">
            <div class="search-input-container">
                <i class="fa fa-search"></i>
                <input type="text" placeholder="Search" id="productSearch">
            </div>
            <button class="product-filter-btn">
                <i class="fa fa-filter"></i>
                More Filter
            </button>
            <div class="dropdown">
                <button class="product-filter-btn dropdown-toggle">
                    Category
                    <i class="fa fa-chevron-down"></i>
                </button>
            </div>
            <div class="dropdown">
                <button class="product-filter-btn dropdown-toggle">
                    Export
                    <i class="fa fa-chevron-down"></i>
                </button>
            </div>
        </div>

        <div class="card-body card-body-no-padding">
            <div class="table-responsive product-table">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>IMAGE</th>
                            <th>NAME</th>
                            <th>CATEGORY</th>
                            <th class="stock-quantity-header">STOCK<br>QUANTITY</th>
                            <th>PRICE</th>
                            <th>DESCRIPTION</th>
                            <th>CREATED BY</th>
                            <th>ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% if products|length > 0 %}
                        {% for product in products %}
                            {% set totalStockQuantity = 0 %}
                            {% for stock in product.stocks %}
                                {% set totalStockQuantity = totalStockQuantity + stock.quantity %}
                            {% endfor %}
                            <tr class="product-row" 
                                data-name="{{ product.Name|lower }}" 
                                data-description="{{ product.description|lower }}"
                                data-category="{{ product.category ? product.category.name|lower : '' }}"
                                data-id="{{ product.id }}"
                                data-price="{{ product.price }}">
                                <td>#{{ product.id }}</td>
                                <td>
                                    {% if product.image %}
                                        <img src="{{ asset('uploads/products/' ~ product.image) }}" 
                                             alt="{{ product.Name }}" 
                                             class="table-product-image">
                                    {% else %}
                                        <div class="product-image-placeholder">
                                            🌺
                                        </div>
                                    {% endif %}
                                </td>
                                <td><strong>{{ product.Name }}</strong></td>
                                <td>
                                    {% if product.category %}
                                        <span class="badge badge-info">{{ product.category.name }}</span>
                                    {% else %}
                                        <span>-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="product-price-text">{{ totalStockQuantity }}</span>
                                </td>
                                <td>
                                    <span class="product-price-text">₱{{ product.price|number_format(2) }}</span>
                                </td>
                                <td>
                                    <span class="product-description-text">
                                        {{ product.description|length > 120 ? product.description|slice(0, 120) ~ '...' : product.description }}
                                    </span>
                                </td>
                                <td>
                                    {% if product.createdBy %}
                                        <div style="display: flex; flex-direction: column; gap: 2px;">
                                            <strong style="font-size: 13px; color: #374151;">{{ product.createdBy.getFullName() }}</strong>
                                            <span style="font-size: 11px; color: #6b7280;">{{ product.createdBy.getRoleLabel() }}</span>
                                        </div>
                                    {% else %}
                                        <span style="color: #9ca3af; font-style: italic;">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="product-actions-cell">
                                        <a href="{{ path('app_product_show', {'id': product.id}) }}" 
                                           class="card-action-btn product-action-btn"
                                           data-view-product-modal="true"
                                           title="View">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        <!-- Search Empty State (hidden by default) -->
                        <tr id="productSearchEmptyState" class="product-search-empty-state" style="display: none;">
                            <td colspan="9" class="stock-empty-state-cell">
                                <div class="stock-empty-state-message">
                                    <i class="fa fa-search" style="font-size: 48px; color: #d1d5db; margin-bottom: 16px;"></i>
                                    <p style="font-size: 16px; color: #6b7280; margin: 0 0 8px 0;">No products found matching your search.</p>
                                    <p style="font-size: 14px; color: #9ca3af; margin: 0;">Try searching with a different term or <a href="{{ path('app_stock_new') }}" class="stock-empty-state-link">create a new product</a></p>
                                </div>
                            </td>
                        </tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- View Product Modal -->
    <div class="admin-modal" id="viewProductModal" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="viewProductModalTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">PRODUCT MANAGEMENT</div>
                    <div class="admin-modal__title" id="viewProductModalTitle">Product Details</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>
            <div class="admin-modal__body" id="viewProductModalBody"></div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Search Functionality
            const searchInput = document.getElementById('productSearch');
            const productRows = document.querySelectorAll('.product-row');
            const searchEmptyState = document.getElementById('productSearchEmptyState');

            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase().trim();
                    let visibleCount = 0;
                    
                    if (productRows.length > 0) {
                        productRows.forEach(row => {
                            // Skip the empty state row
                            if (row.classList.contains('product-search-empty-state')) {
                                return;
                            }
                            
                            const productName = row.getAttribute('data-name') || '';
                            const description = row.getAttribute('data-description') || '';
                            const category = row.getAttribute('data-category') || '';
                            const id = row.getAttribute('data-id') || '';
                            const price = row.getAttribute('data-price') || '';
                            
                            // Search in multiple fields
                            const matchesSearch = searchTerm === '' || 
                                productName.includes(searchTerm) || 
                                description.includes(searchTerm) ||
                                category.includes(searchTerm) ||
                                id.toString().includes(searchTerm) ||
                                price.toString().includes(searchTerm);
                            
                            if (matchesSearch) {
                                row.style.display = '';
                                visibleCount++;
                            } else {
                                row.style.display = 'none';
                            }
                        });
                    }
                    
                    // Show/hide empty state based on search results
                    if (searchEmptyState) {
                        if (searchTerm !== '' && visibleCount === 0 && productRows.length > 0) {
                            searchEmptyState.style.display = '';
                        } else {
                            searchEmptyState.style.display = 'none';
                        }
                    }
                });
            }
        });
    </script>

    <!-- New Stock Entry Modal (from Products) -->
    <div class="admin-modal" id="newStockModalFromProducts" aria-hidden="true">
        <div class="admin-modal__overlay" data-modal-close="true"></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="newStockModalFromProductsTitle">
            <div class="admin-modal__header">
                <div>
                    <div class="admin-modal__kicker">STOCK MANAGEMENT</div>
                    <div class="admin-modal__title" id="newStockModalFromProductsTitle">New Stock Entry</div>
                </div>
                <button type="button" class="admin-modal__close" aria-label="Close" data-modal-close="true">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <div class="admin-modal__body" id="newStockModalFromProductsBody">
                {{ include('stock/_form.html.twig', {
                    form: stockForm,
                    button_label: 'Create Stock Entry',
                    action: path('app_stock_new'),
                    show_cancel: false
                }) }}
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const openBtn = document.getElementById('openNewStockModalFromProducts');
            const modal = document.getElementById('newStockModalFromProducts');
            const modalBody = document.getElementById('newStockModalFromProductsBody');
            const viewModal = document.getElementById('viewProductModal');
            const viewModalBody = document.getElementById('viewProductModalBody');
            const viewLinks = document.querySelectorAll('a[data-view-product-modal="true"]');

            function openModal() {
                if (!modal) return;
                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
                initStockImageDropzone(modal);
            }

            function closeModal() {
                if (!modal) return;
                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
            }

            function initStockImageDropzone(rootEl) {
                const root = rootEl || document;
                const dropzone = root.querySelector('#imageDropzone');
                let fileInput = root.querySelector('#imageFileInput');
                if (!fileInput) fileInput = root.querySelector('input[type="file"][name*="productImage"]');
                const previewContainer = root.querySelector('#imagePreviewContainer');
                const preview = root.querySelector('#imagePreview');
                const removeBtn = root.querySelector('#imageRemoveBtn');

                if (!dropzone || !fileInput || !previewContainer || !preview) return;
                if (dropzone.dataset.bound === 'true') return;
                dropzone.dataset.bound = 'true';

                const preventDefaults = (e) => { e.preventDefault(); e.stopPropagation(); };

                ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                    dropzone.addEventListener(eventName, preventDefaults, false);
                });

                dropzone.addEventListener('click', function(e) {
                    if (e.target.closest('.image-remove-btn')) return;
                    fileInput.click();
                });

                dropzone.addEventListener('dragover', function() {
                    dropzone.classList.add('dragover');
                });

                dropzone.addEventListener('dragleave', function() {
                    dropzone.classList.remove('dragover');
                });

                dropzone.addEventListener('drop', function(e) {
                    dropzone.classList.remove('dragover');
                    const files = e.dataTransfer.files;
                    if (!files || files.length === 0) return;

                    const file = files[0];
                    const isImage = (file.type && file.type.startsWith('image/')) || /\.(jpg|jpeg|png|gif|bmp|webp|svg)$/i.test(file.name || '');
                    if (!isImage) {
                        alert('Please select an image file (JPG, PNG, GIF, etc.).');
                        return;
                    }

                    try {
                        const dt = new DataTransfer();
                        dt.items.add(file);
                        fileInput.files = dt.files;
                        fileInput.dispatchEvent(new Event('change', { bubbles: true }));
                    } catch (err) {
                        // ignore
                    }
                });

                fileInput.addEventListener('change', function() {
                    const file = this.files && this.files[0];
                    if (!file) return;

                    const isImage = (file.type && file.type.startsWith('image/')) || /\.(jpg|jpeg|png|gif|bmp|webp|svg)$/i.test(file.name || '');
                    if (!isImage) return;

                    const reader = new FileReader();
                    reader.onload = function(ev) {
                        preview.src = ev.target.result;
                        preview.style.display = 'block';
                        previewContainer.style.display = 'block';
                        dropzone.style.display = 'none';
                    };
                    reader.readAsDataURL(file);
                });

                if (removeBtn) {
                    removeBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        try {
                            const dt = new DataTransfer();
                            fileInput.files = dt.files;
                        } catch (err) {
                            fileInput.value = '';
                        }
                        preview.src = '';
                        previewContainer.style.display = 'none';
                        dropzone.style.display = 'block';
                    });
                }
            }

            if (openBtn) openBtn.addEventListener('click', openModal);

            if (modal) {
                modal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close=\"true\"]')) closeModal();
                });
                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
                });
            }

            function openViewModal() {
                if (!viewModal) return;
                viewModal.classList.add('is-open');
                viewModal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
            }

            function closeViewModal() {
                if (!viewModal) return;
                viewModal.classList.remove('is-open');
                viewModal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
                if (viewModalBody) viewModalBody.innerHTML = '';
            }

            viewLinks.forEach(link => {
                link.addEventListener('click', async function(ev) {
                    ev.preventDefault();
                    const url = this.getAttribute('href');
                    if (!url) return;

                    try {
                        const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await res.text();
                        if (viewModalBody) viewModalBody.innerHTML = html;
                        openViewModal();
                    } catch (err) {
                        window.location.href = url;
                    }
                });
            });

            if (viewModal) {
                viewModal.addEventListener('click', function(e) {
                    if (e.target && e.target.matches('[data-modal-close="true"]')) closeViewModal();
                });
            }

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && viewModal && viewModal.classList.contains('is-open')) {
                    closeViewModal();
                }
            });

            document.addEventListener('submit', async function(e) {
                const formEl = e.target;
                if (!modal || !modal.classList.contains('is-open')) return;
                if (!formEl || !formEl.matches('form[data-stock-form=\"true\"]')) return;

                e.preventDefault();
                try {
                    const res = await fetch(formEl.action, {
                        method: 'POST',
                        body: new FormData(formEl),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (res.ok) {
                        const data = await res.json();
                        window.location.href = (data && data.redirectUrl) ? data.redirectUrl : window.location.href;
                        return;
                    }

                    const html = await res.text();
                    if (modalBody) {
                        modalBody.innerHTML = html;
                        initStockImageDropzone(modal);
                    }
                } catch (err) {
                    formEl.submit();
                }
            }, true);
        });
    </script>
{% endblock %}