{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    
    <div class="form-group">
        {{ form_label(form.Name, 'Flower Name *') }}
        {{ form_widget(form.Name, {'attr': {'placeholder': ''}}) }}
        {{ form_errors(form.Name) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description, 'Description *') }}
        {{ form_widget(form.description, {'attr': {'placeholder': 'Describe the flower, its features, and care instructions...'}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-group">
        {{ form_label(form.price, 'Price (₱) *') }}
        {{ form_widget(form.price, {'attr': {'placeholder': '0.00', 'step': '0.01', 'min': '0'}}) }}
        {{ form_errors(form.price) }}
    </div>

    <div class="form-group">
        {{ form_label(form.image, 'Flower Image') }}
        {{ form_widget(form.image) }}
        {{ form_errors(form.image) }}
        <small class="text-muted" style="display: block; margin-top: 0.5rem;">
            Upload a beautiful image of your flower (JPG, PNG, GIF)
        </small>
    </div>

    <div style="margin-top: 2rem;">
        <button type="submit" class="btn btn-success">{{ button_label|default('💾 Save Flower') }}</button>
    </div>

{{ form_end(form) }}
