# Copy to .env (or merge with your existing .env) before: docker compose up -d --build

APP_ENV=prod
APP_SECRET=change_me_to_a_long_random_string

DEFAULT_URI=http://localhost:8081/

MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=flower_shop
MYSQL_USER=flower_user
MYSQL_PASSWORD=flower_secret

# Host must be "mysql" (Docker service name), not 127.0.0.1
DATABASE_URL=mysql://flower_user:flower_secret@mysql:3306/flower_shop?serverVersion=8.0&charset=utf8mb4

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

MAILER_DSN=null://null
MAILER_FROM_ADDRESS=noreply@example.com
MAILER_FROM_NAME="Flower Shop"

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase
